---
import '../styles/global.css';

export interface Props {
  title?: string;
}

const { title = 'Nexus Infinity Corporation — CRM + IA Multicanal' } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;700;900&family=Syne:wght@400;500;600;700;800&family=JetBrains+Mono:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="font-body bg-bg-dark text-text-base overflow-x-hidden cursor-default">
    <slot />
  </body>
</html>
