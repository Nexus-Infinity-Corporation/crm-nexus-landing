---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Navbar from '@/components/Navbar.astro';
import CRMHero from '@/components/crm/CRMHero.astro';
import CRMChannels from '@/components/crm/CRMChannels.astro';
import CRMPricing from '@/components/crm/CRMPricing.astro';
import Demo from '@/components/Demo.astro';
import Footer from '@/components/Footer.astro';
---

<BaseLayout
  title="Nexus CRM — CRM Multicanal con Inteligencia Artificial"
  description="Nexus CRM: gestiona Facebook, Instagram, TikTok, WhatsApp y más desde un panel unificado. Agentes de IA que atienden y convierten clientes 24/7 sin intervención humana."
>
  <!-- Fixed Background Effects -->
  <div class="bg-grid-pattern fixed top-0 left-0 w-full h-full pointer-events-none z-0"></div>
  <div class="fixed top-0 left-0 w-full h-full pointer-events-none z-0 overflow-hidden">
    <div class="absolute w-[500px] h-[500px] bg-secondary rounded-full blur-[80px] opacity-[0.12] -top-[100px] -right-[100px] animate-float-slow"></div>
    <div class="absolute w-[400px] h-[400px] bg-primary rounded-full blur-[80px] opacity-[0.12] bottom-[20%] -left-[100px] animate-float-2"></div>
    <div class="absolute w-[300px] h-[300px] bg-accent rounded-full blur-[80px] opacity-[0.12] top-1/2 right-[20%] animate-float-3"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10">
    <Navbar />
    <main>
      <CRMHero />
      <CRMChannels />
      <!-- <CRMAutomation /> -->
      <!-- <CRMAnalyticsPricing /> -->
      <CRMPricing />
      <Demo source='CRM'/>
    </main>
    <Footer />
  </div>
</BaseLayout>

<script>
  function initCRMPage() {
    // ── Language toggle ────────────────────────────────────────────
    const btnEn = document.getElementById('btn-en');
    const btnEs = document.getElementById('btn-es');

    function setLang(lang: 'en' | 'es') {
      const show = lang === 'en' ? '.t-en' : '.t-es';
      const hide = lang === 'en' ? '.t-es' : '.t-en';
      document.querySelectorAll<HTMLElement>(show).forEach(el => el.classList.remove('hidden'));
      document.querySelectorAll<HTMLElement>(hide).forEach(el => el.classList.add('hidden'));
      const active = 'lang-btn font-mono text-[11px] tracking-[2px] uppercase px-3 py-1 rounded-full border transition-all bg-[rgba(0,212,255,0.12)] border-primary text-primary';
      const idle   = 'lang-btn font-mono text-[11px] tracking-[2px] uppercase px-3 py-1 rounded-full border transition-all bg-transparent border-[rgba(0,212,255,0.2)] text-text-muted';
      if (btnEn && btnEs) {
        btnEn.className = lang === 'en' ? active : idle;
        btnEs.className = lang === 'es' ? active : idle;
      }
      localStorage.setItem('nxLang', lang);
    }

    if (btnEn) btnEn.addEventListener('click', () => setLang('en'));
    if (btnEs) btnEs.addEventListener('click', () => setLang('es'));

    // Show lang toggle in navbar (hidden by default)
    const langToggle = document.getElementById('lang-toggle');
    if (langToggle) langToggle.classList.replace('hidden', 'flex');

    const saved = localStorage.getItem('nxLang') as 'en' | 'es' | null;
    setLang(saved === 'es' ? 'es' : 'en');

    const observer = new IntersectionObserver(
      (entries) => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
      { threshold: 0.1 }
    );
    document.querySelectorAll('.observe-anim').forEach(el => observer.observe(el));

    setInterval(() => {
      document.querySelectorAll<HTMLElement>('.b-cnt').forEach(el => {
        if (Math.random() > 0.75) {
          const current = parseInt(el.textContent || '0');
          el.textContent = String(Math.max(1, current + (Math.random() > 0.5 ? 1 : -1)));
        }
      });
    }, 2500);
  }

  document.addEventListener('astro:page-load', initCRMPage);
</script>

