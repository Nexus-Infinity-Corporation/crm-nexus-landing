---
import BaseLayout from "@/layouts/BaseLayout.astro";

---

<BaseLayout
    title="Nexus Demo — Schedule Your Personalized CRM Demo"
    description="Request a personalized demo of Nexus CRM. Experience how our AI-powered multichannel CRM can transform your customer interactions and boost your sales. Schedule your free demo today!"
>
<!-- Simple Navbar -->
    <div class="flex items-center justify-between px-5 pt-5 md:px-10 md:pt-10">
    <a href="/" class="flex items-center gap-3 no-underline">
        <div class="animate-float">
          <svg width="36" height="36" viewBox="0 0 36 36">
            <polygon points="18,2 34,10 34,26 18,34 2,26 2,10" fill="none" stroke="url(#lg1)" stroke-width="2"/>
            <polygon points="18,8 28,13 28,23 18,28 8,23 8,13" fill="rgba(0,212,255,0.1)" stroke="url(#lg1)" stroke-width="1"/>
            <circle cx="18" cy="18" r="4" fill="url(#lg1)"/>
            <defs>
              <linearGradient id="lg1" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#00D4FF"/>
                <stop offset="100%" stop-color="#7B2FFF"/>
              </linearGradient>
            </defs>
          </svg>
        </div>
        <div>
          <span class="block font-display text-lg font-black text-primary tracking-[3px] leading-none">NEXUS</span>
          <span class="block font-mono text-[8px] text-text-muted tracking-[2px] mt-0.5">INFINITY CORPORATION</span>
        </div>
    </a>
    </div>
<section class="py-5 relative" id="demo">
  <div class="max-w-[1280px] mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-[70px] items-center">
      <!-- Left -->
      <div>
        <!-- Language toggle -->
    <div class="flex items-center pb-5 gap-2">
      <button id="btn-en" class="lang-btn font-mono text-[11px] tracking-[2px] uppercase px-4 py-1.5 rounded-full border transition-all bg-[rgba(0,212,255,0.12)] border-primary text-primary">EN</button>
      <button id="btn-es" class="lang-btn font-mono text-[11px] tracking-[2px] uppercase px-4 py-1.5 rounded-full border transition-all bg-transparent border-[rgba(0,212,255,0.2)] text-text-muted">ES</button>
    </div>
        <div class="inline-flex items-center gap-2 font-mono text-[11px] tracking-[3px] text-primary uppercase bg-[rgba(0,212,255,0.08)] border border-[rgba(0,212,255,0.4)] px-4 py-1.5 rounded-full mb-5">
          <span class="w-1.5 h-1.5 bg-primary rounded-full animate-pulse-dot"></span>
          <span class="t-en">Ready to get started?</span>
          <span class="t-es hidden">¿Listo para empezar?</span>
        </div>
        <h2 class="font-display text-[clamp(32px,4vw,52px)] font-bold leading-[1.1] gradient-text mb-5">
          <span class="t-en">Request your<br/>Meeting</span>
          <span class="t-es hidden">Solicita tu <br/>Reunion</span>
        </h2>
        <p class="text-lg text-text-muted leading-[1.7] max-w-[600px]">
          <span class="t-en">Schedule a 30-minute session. We’ll show you the platform configured for your specific industry.</span>
          <span class="t-es hidden">Agenda una sesión de 30 minutos. Te mostramos la plataforma configurada para tu industria específica.</span>
        </p>
        <div class="flex flex-col gap-2.5 mt-7">
          {[
            { en: 'No credit card required',          es: 'Sin tarjeta de crédito requerida' },
            { en: '14-day free trial',                 es: 'Prueba gratuita de 14 días' },
            { en: 'Free onboarding included',          es: 'Onboarding incluido sin costo' },
            { en: 'Setup in less than 2 hours',        es: 'Configuración en menos de 2 horas' },
          ].map(b => (
            <div class="flex items-center gap-2.5 text-sm text-text-muted">
              <span class="text-accent2 font-bold">✓</span>
              <span class="t-en">{b.en}</span>
              <span class="t-es hidden">{b.es}</span>
            </div>
          ))}
        </div>

        <!-- Calendly direct-schedule card -->
        <!-- <div class="mt-8 bg-bg-card border border-[rgba(123,47,255,0.35)] rounded-2xl p-5 shadow-[0_0_24px_rgba(123,47,255,0.1)]">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-[rgba(123,47,255,0.15)] border border-[rgba(123,47,255,0.3)] flex items-center justify-center text-[18px] shrink-0">📅</div>
            <div class="flex-1">
              <p class="font-display text-[13px] font-bold text-white mb-1">
                <span class="t-en">Prefer to pick a time yourself?</span>
                <span class="t-es hidden">¿Prefieres elegir el horario tú mismo?</span>
              </p>
              <p class="text-[12px] text-text-muted mb-3">
                <span class="t-en">Book a 30-minute slot directly on our calendar — no waiting.</span>
                <span class="t-es hidden">Reserva un espacio de 30 minutos directo en nuestro calendario, sin esperas.</span>
              </p>
              <a
                href="https://calendly.com/sale-nexusinfinitycorp/30min"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 font-mono text-[11px] tracking-[1.5px] uppercase px-4 py-2 rounded-full bg-[rgba(123,47,255,0.12)] border border-[rgba(123,47,255,0.4)] text-[#B088FF] hover:bg-[rgba(123,47,255,0.22)] hover:border-[#B088FF] hover:shadow-[0_0_18px_rgba(123,47,255,0.3)] transition-all duration-200"
              >
                <span class="t-en">Schedule on Calendly →</span>
                <span class="t-es hidden">Agendar en Calendly →</span>
              </a>
            </div>
          </div>
        </div> -->
      </div>

      <!-- Right: Form -->
      <div class="bg-bg-card border border-[rgba(0,212,255,0.4)] rounded-2xl p-5 sm:p-8 shadow-glow-primary">
        <div class="font-display text-[17px] font-bold mb-5 text-center text-primary">
          <span class="t-en">Schedule your meeting</span>
          <span class="t-es hidden">Agenda una Reunion</span>
        </div>
        <!-- Success message (hidden by default) -->
        <div id="form-success" class="hidden text-center py-6">
          <div class="text-4xl mb-3">🎉</div>
          <p class="font-display text-lg font-bold text-primary mb-2">
            <span class="t-en">Request sent!</span>
            <span class="t-es hidden">¡Solicitud enviada!</span>
          </p>
          <p class="text-sm text-text-muted mb-5">
            <span class="t-en">We'll be in touch within 2 hours. Or book your slot right now:</span>
            <span class="t-es hidden">Te contactaremos en las próximas 2 horas. O agenda tu espacio ahora mismo:</span>
          </p>
          <!-- <a
            href="https://calendly.com/sale-nexusinfinitycorp/30min"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2.5 font-mono text-[11px] tracking-[2px] uppercase px-6 py-3 rounded-full bg-gradient-to-br from-secondary to-accent text-white font-bold hover:shadow-[0_0_24px_rgba(123,47,255,0.5)] transition-all duration-300"
          >
            📅
            <span class="t-en">Book on Calendly</span>
            <span class="t-es hidden">Agendar en Calendly</span>
          </a> -->
        </div>
        <!-- Error message (hidden by default) -->
        <div id="form-error" class="hidden mb-4 px-4 py-3 rounded-lg bg-[rgba(255,60,60,0.1)] border border-[rgba(255,60,60,0.4)] text-sm text-red-400 text-center"></div>

        <div id="form-fields">

        <div class="mb-3.5">
          <label class="block text-[11px] text-text-muted mb-1.5 font-mono">
            <span class="t-en">Full name</span>
            <span class="t-es hidden">Nombre completo</span>
          </label>
          <input id="field-name" type="text" placeholder="Juan García" required class="w-full bg-bg-dark border border-[rgba(0,212,255,0.15)] rounded-lg px-3.5 py-2.5 text-text-base font-body text-[13px] transition-all focus:outline-none focus:border-primary focus:shadow-[0_0_0_3px_rgba(0,212,255,0.1)] placeholder:text-text-dim" />
        </div>
        <div class="mb-3.5">
          <label class="block text-[11px] text-text-muted mb-1.5 font-mono">
            <span class="t-en">Company</span>
            <span class="t-es hidden">Empresa</span>
          </label>
          <input id="field-company" type="text" placeholder="My Company Inc" class="w-full bg-bg-dark border border-[rgba(0,212,255,0.15)] rounded-lg px-3.5 py-2.5 text-text-base font-body text-[13px] transition-all focus:outline-none focus:border-primary focus:shadow-[0_0_0_3px_rgba(0,212,255,0.1)] placeholder:text-text-dim" />
        </div>
        <div class="mb-3.5">
          <label class="block text-[11px] text-text-muted mb-1.5 font-mono">
            <span class="t-en">Corporate email</span>
            <span class="t-es hidden">Email corporativo</span>
          </label>
          <input id="field-email" type="email" placeholder="juan@empresa.com" required class="w-full bg-bg-dark border border-[rgba(0,212,255,0.15)] rounded-lg px-3.5 py-2.5 text-text-base font-body text-[13px] transition-all focus:outline-none focus:border-primary focus:shadow-[0_0_0_3px_rgba(0,212,255,0.1)] placeholder:text-text-dim" />

        </div>
        <div class="mb-3.5">
          <label class="block text-[11px] text-text-muted mb-1.5 font-mono">
            <span class="t-en">Phone</span>
            <span class="t-es hidden">Teléfono</span>
          </label>
          <input id="field-phone" type="tel" placeholder="+1 555 0000" class="w-full bg-bg-dark border border-[rgba(0,212,255,0.15)] rounded-lg px-3.5 py-2.5 text-text-base font-body text-[13px] transition-all focus:outline-none focus:border-primary focus:shadow-[0_0_0_3px_rgba(0,212,255,0.1)] placeholder:text-text-dim" />
        </div>
        <div class="mb-5">
          <label class="block text-[11px] text-text-muted mb-1.5 font-mono">
            <span class="t-en">How many agents does your team have?</span>
            <span class="t-es hidden">¿Cuántos agentes tiene tu equipo?</span>
          </label>
          <select id="field-agents" class="w-full bg-bg-dark border border-[rgba(0,212,255,0.15)] rounded-lg px-3.5 py-2.5 text-text-base font-body text-[13px] transition-all focus:outline-none focus:border-primary focus:shadow-[0_0_0_3px_rgba(0,212,255,0.1)]">
            <option>1-5</option>
            <option>6-20</option>
            <option>21-50</option>
            <option>50+</option>
          </select>
        </div>
        <button
          id="submit-btn"
          type="button"
          class="btn-primary-glow w-full flex items-center justify-center gap-2.5 bg-gradient-to-br from-primary to-secondary text-white font-bold text-[15px] px-8 py-[15px] rounded-full border-none cursor-pointer shadow-glow-primary disabled:opacity-60 disabled:cursor-not-allowed"
        >
          <span id="btn-label-en" class="relative z-10 t-en">🚀 Request a meeting</span>
          <span id="btn-label-es" class="relative z-10 t-es hidden">🚀 Solicitar Reunion</span>
        </button>
        <p class="text-center text-[11px] text-text-dim mt-2.5">
          <span class="t-en">No spam. You agree to our Privacy Policy.</span>
          <span class="t-es hidden">Sin spam. Aceptas nuestra Política de Privacidad.</span>
        </p>
        </div>
      </div>
    </div>
  </div>
</section>
</BaseLayout>

<script>
  import { sendDemoEmail } from '@/scripts/send-email';

  function initDemoFormPage() {
    let currentLang: 'en' | 'es' = 'en';

    const btnEn = document.getElementById('btn-en') as HTMLButtonElement | null;
    const btnEs = document.getElementById('btn-es') as HTMLButtonElement | null;

    function setLang(lang: 'en' | 'es') {
      currentLang = lang;
      const show = lang === 'en' ? '.t-en' : '.t-es';
      const hide = lang === 'en' ? '.t-es' : '.t-en';
      document.querySelectorAll<HTMLElement>(show).forEach(el => el.classList.remove('hidden'));
      document.querySelectorAll<HTMLElement>(hide).forEach(el => el.classList.add('hidden'));
      const active = 'bg-[rgba(0,212,255,0.12)] border-primary text-primary';
      const idle   = 'bg-transparent border-[rgba(0,212,255,0.2)] text-text-muted';
      const base   = 'lang-btn font-mono text-[11px] tracking-[2px] uppercase px-4 py-1.5 rounded-full border transition-all';
      if (btnEn && btnEs) {
        btnEn.className = lang === 'en' ? `${base} ${active}` : `${base} ${idle}`;
        btnEs.className = lang === 'es' ? `${base} ${active}` : `${base} ${idle}`;
      }
      localStorage.setItem('nxLang', lang);
    }

    if (btnEn) btnEn.addEventListener('click', () => setLang('en'));
    if (btnEs) btnEs.addEventListener('click', () => setLang('es'));

    const saved = localStorage.getItem('nxLang') as 'en' | 'es' | null;
    setLang(saved === 'es' ? 'es' : 'en');

    // ── Form submission ──────────────────────────────────────────────────────
    const submitBtn   = document.getElementById('submit-btn') as HTMLButtonElement | null;
    const formFields  = document.getElementById('form-fields');
    const formSuccess = document.getElementById('form-success');
    const formError   = document.getElementById('form-error') as HTMLElement | null;

    const fieldName    = document.getElementById('field-name')    as HTMLInputElement | null;
    const fieldCompany = document.getElementById('field-company') as HTMLInputElement | null;
    const fieldEmail   = document.getElementById('field-email')   as HTMLInputElement | null;
    const fieldPhone   = document.getElementById('field-phone')   as HTMLInputElement | null;
    const fieldAgents  = document.getElementById('field-agents')  as HTMLSelectElement | null;

    if (!submitBtn || !formFields || !formSuccess || !formError || !fieldName || !fieldEmail || !fieldAgents) return;

    submitBtn.addEventListener('click', async () => {
      if (!fieldName.value.trim() || !fieldEmail.value.trim()) {
        formError.textContent = currentLang === 'es'
          ? 'Por favor completa los campos requeridos (nombre y email).'
          : 'Please fill in the required fields (name and email).';
        formError.classList.remove('hidden');
        return;
      }

      formError.classList.add('hidden');
      submitBtn.disabled = true;
      submitBtn.innerHTML = currentLang === 'es'
        ? '<span class="relative z-10">⏳ Enviando...</span>'
        : '<span class="relative z-10">⏳ Sending...</span>';

      const result = await sendDemoEmail({
        name:    fieldName.value.trim(),
        company: fieldCompany?.value.trim() ?? '',
        email:   fieldEmail.value.trim(),
        phone:   fieldPhone?.value.trim() ?? '',
        agents:  fieldAgents.value,
        lang:    currentLang,
        source:  'MAIN',
      });

      if (result.success) {
        formFields.classList.add('hidden');
        formSuccess.classList.remove('hidden');
        setLang(currentLang);
      } else {
        submitBtn.disabled = false;
        submitBtn.innerHTML = currentLang === 'es'
          ? '<span class="relative z-10">🚀 Solicitar Reunion</span>'
          : '<span class="relative z-10">🚀 Request a meeting</span>';
        formError.textContent = result.error ?? (currentLang === 'es'
          ? 'Algo salió mal. Intenta de nuevo.'
          : 'Something went wrong. Please try again.');
        formError.classList.remove('hidden');
      }
    });
  }

  document.addEventListener('astro:page-load', initDemoFormPage);
</script>
