---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Footer from '@/components/Footer.astro';

const industries = [
  { icon: '🏦', nameEn: 'Financial Services',     nameEs: 'Servicios Financieros',    platform: 'both', descEn: 'Client management & back-office automation',          descEs: 'Gestión de clientes y automatización contable' },
  { icon: '📊', nameEn: 'Accounting',              nameEs: 'Contabilidad',              platform: 'erp',  descEn: 'Automated ledgers, invoicing & reporting',           descEs: 'Libros contables, facturación e informes' },
  { icon: '👥', nameEn: 'Human Resources',         nameEs: 'Recursos Humanos',          platform: 'erp',  descEn: 'Payroll, recruitment & performance tracking',        descEs: 'Nómina, reclutamiento y desempeño' },
  { icon: '🏭', nameEn: 'Manufacturing',           nameEs: 'Manufactura',               platform: 'erp',  descEn: 'Production planning, BOM & shop floor control',      descEs: 'Planificación de producción y control de planta' },
  { icon: '🛒', nameEn: 'Retail & E-commerce',     nameEs: 'Retail y E-commerce',       platform: 'both', descEn: 'Omnichannel sales, inventory & loyalty programs',    descEs: 'Ventas omnicanal, inventario y fidelización' },
  { icon: '🏠', nameEn: 'Real Estate',             nameEs: 'Bienes Raíces',             platform: 'crm',  descEn: 'Lead pipelines, property follow-ups & closings',     descEs: 'Pipelines de leads, seguimiento y cierres' },
  { icon: '🏥', nameEn: 'Healthcare',              nameEs: 'Salud',                     platform: 'both', descEn: 'Patient CRM, billing & supply chain management',    descEs: 'CRM para pacientes, facturación y supply chain' },
  { icon: '🎓', nameEn: 'Education',               nameEs: 'Educación',                 platform: 'crm',  descEn: 'Enrollment automation, student engagement & LMS',   descEs: 'Automatización de matrículas y enganche estudiantil' },
  { icon: '🏗️', nameEn: 'Construction',           nameEs: 'Construcción',              platform: 'erp',  descEn: 'Project costing, procurement & subcontractor mgmt', descEs: 'Costos de proyecto, compras y subcontratistas' },
  { icon: '🚚', nameEn: 'Logistics',               nameEs: 'Logística',                 platform: 'erp',  descEn: 'Fleet, warehouse & distribution management',        descEs: 'Gestión de flota, almacén y distribución' },
  { icon: '⚖️', nameEn: 'Legal Services',          nameEs: 'Servicios Legales',         platform: 'crm',  descEn: 'Case tracking, client communication & billing',     descEs: 'Seguimiento de casos, comunicación y facturación' },
  { icon: '🛡️', nameEn: 'Insurance',              nameEs: 'Seguros',                   platform: 'crm',  descEn: 'Policy management, claims & renewal automation',    descEs: 'Gestión de pólizas, siniestros y renovaciones' },
  { icon: '🍽️', nameEn: 'Hospitality',            nameEs: 'Hospitalidad',              platform: 'crm',  descEn: 'Guest CRM, reservations & loyalty campaigns',       descEs: 'CRM de huéspedes, reservas y campañas de fidelización' },
  { icon: '💻', nameEn: 'Technology',              nameEs: 'Tecnología',                platform: 'both', descEn: 'Subscription billing, support & DevOps procurement', descEs: 'Facturación, soporte y adquisición DevOps' },
  { icon: '📡', nameEn: 'Telecommunications',      nameEs: 'Telecomunicaciones',        platform: 'crm',  descEn: 'Subscriber management, support & upsell campaigns', descEs: 'Gestión de suscriptores, soporte y upsell' },
  { icon: '⚡', nameEn: 'Energy & Utilities',      nameEs: 'Energía y Servicios',       platform: 'erp',  descEn: 'Asset management, billing & regulatory compliance', descEs: 'Gestión de activos, facturación y cumplimiento' },
];

const regions = [
  {
    glob: '🌎',
    labelEn: 'North America',
    labelEs: 'América del Norte',
    countries: [
      { flag: '🇺🇸', nameEn: 'United States',   nameEs: 'Estados Unidos' },
      { flag: '🇨🇦', nameEn: 'Canada',           nameEs: 'Canadá' },
      { flag: '🇲🇽', nameEn: 'Mexico',           nameEs: 'México' },
    ],
  },
  {
    glob: '🌎',
    labelEn: 'Central America',
    labelEs: 'América Central',
    countries: [
      { flag: '🇬🇹', nameEn: 'Guatemala',        nameEs: 'Guatemala' },
      { flag: '🇧🇿', nameEn: 'Belize',           nameEs: 'Belice' },
      { flag: '🇭🇳', nameEn: 'Honduras',         nameEs: 'Honduras' },
      { flag: '🇸🇻', nameEn: 'El Salvador',      nameEs: 'El Salvador' },
      { flag: '🇳🇮', nameEn: 'Nicaragua',        nameEs: 'Nicaragua' },
      { flag: '🇨🇷', nameEn: 'Costa Rica',       nameEs: 'Costa Rica' },
      { flag: '🇵🇦', nameEn: 'Panama',           nameEs: 'Panamá' },
    ],
  },
  {
    glob: '🌎',
    labelEn: 'The Caribbean',
    labelEs: 'El Caribe',
    countries: [
      { flag: '🇨🇺', nameEn: 'Cuba',                    nameEs: 'Cuba' },
      { flag: '🇯🇲', nameEn: 'Jamaica',                 nameEs: 'Jamaica' },
      { flag: '🇭🇹', nameEn: 'Haiti',                   nameEs: 'Haití' },
      { flag: '🇩🇴', nameEn: 'Dominican Republic',      nameEs: 'Rep. Dominicana' },
      { flag: '🇵🇷', nameEn: 'Puerto Rico',             nameEs: 'Puerto Rico' },
      { flag: '🇹🇹', nameEn: 'Trinidad & Tobago',       nameEs: 'Trinidad y Tobago' },
      { flag: '🇧🇸', nameEn: 'Bahamas',                 nameEs: 'Bahamas' },
      { flag: '🇧🇧', nameEn: 'Barbados',                nameEs: 'Barbados' },
      { flag: '🇱🇨', nameEn: 'Saint Lucia',            nameEs: 'Santa Lucía' },
      { flag: '🇬🇩', nameEn: 'Grenada',                nameEs: 'Granada' },
      { flag: '🇻🇨', nameEn: 'Saint Vincent',          nameEs: 'San Vicente' },
      { flag: '🇦🇬', nameEn: 'Antigua & Barbuda',      nameEs: 'Antigua y Barbuda' },
    ],
  },
  {
    glob: '🌎',
    labelEn: 'South America',
    labelEs: 'América del Sur',
    countries: [
      { flag: '🇧🇷', nameEn: 'Brazil',      nameEs: 'Brasil' },
      { flag: '🇦🇷', nameEn: 'Argentina',   nameEs: 'Argentina' },
      { flag: '🇨🇱', nameEn: 'Chile',       nameEs: 'Chile' },
      { flag: '🇨🇴', nameEn: 'Colombia',    nameEs: 'Colombia' },
      { flag: '🇵🇪', nameEn: 'Peru',        nameEs: 'Perú' },
      { flag: '🇻🇪', nameEn: 'Venezuela',   nameEs: 'Venezuela' },
      { flag: '🇪🇨', nameEn: 'Ecuador',     nameEs: 'Ecuador' },
      { flag: '🇧🇴', nameEn: 'Bolivia',     nameEs: 'Bolivia' },
      { flag: '🇵🇾', nameEn: 'Paraguay',    nameEs: 'Paraguay' },
      { flag: '🇺🇾', nameEn: 'Uruguay',     nameEs: 'Uruguay' },
      { flag: '🇬🇾', nameEn: 'Guyana',      nameEs: 'Guyana' },
      { flag: '🇸🇷', nameEn: 'Suriname',    nameEs: 'Surinam' },
    ],
  },
  {
    glob: '🌍',
    labelEn: 'European Countries',
    labelEs: 'Países de Europa',
    countries: [
      { flag: '🇪🇸', nameEn: 'Spain',           nameEs: 'España' },
      { flag: '🇵🇹', nameEn: 'Portugal',         nameEs: 'Portugal' },
      { flag: '🇫🇷', nameEn: 'France',           nameEs: 'Francia' },
      { flag: '🇩🇪', nameEn: 'Germany',          nameEs: 'Alemania' },
      { flag: '🇮🇹', nameEn: 'Italy',            nameEs: 'Italia' },
      { flag: '🇬🇧', nameEn: 'United Kingdom',   nameEs: 'Reino Unido' },
      { flag: '🇳🇱', nameEn: 'Netherlands',      nameEs: 'Países Bajos' },
      { flag: '🇧🇪', nameEn: 'Belgium',          nameEs: 'Bélgica' },
      { flag: '🇨🇭', nameEn: 'Switzerland',      nameEs: 'Suiza' },
      { flag: '🇦🇹', nameEn: 'Austria',          nameEs: 'Austria' },
      { flag: '🇸🇪', nameEn: 'Sweden',           nameEs: 'Suecia' },
      { flag: '🇳🇴', nameEn: 'Norway',           nameEs: 'Noruega' },
    ],
  },
];
---

<BaseLayout title="Nexus Infinity — Elige tu Plataforma">
  <!-- Fixed Background Effects -->
  <div class="bg-grid-pattern fixed top-0 left-0 w-full h-full pointer-events-none z-0"></div>
  <div class="fixed top-0 left-0 w-full h-full pointer-events-none z-0 overflow-hidden">
    <div class="absolute w-[500px] h-[500px] bg-secondary rounded-full blur-[80px] opacity-[0.12] -top-[100px] -right-[100px] animate-float-slow"></div>
    <div class="absolute w-[400px] h-[400px] bg-primary rounded-full blur-[80px] opacity-[0.12] bottom-[20%] -left-[100px] animate-float-2"></div>
    <div class="absolute w-[300px] h-[300px] bg-accent rounded-full blur-[80px] opacity-[0.12] top-1/2 right-[20%] animate-float-3"></div>
  </div>

  <div class="relative z-10">
    <!-- <Navbar /> -->
      <div class="flex items-center pt-5 pl-5 md:pt-10 md:pl-10 gap-3 no-underline">
        <div class="animate-float">
          <svg width="36" height="36" viewBox="0 0 36 36">
            <polygon points="18,2 34,10 34,26 18,34 2,26 2,10" fill="none" stroke="url(#lg1)" stroke-width="2"/>
            <polygon points="18,8 28,13 28,23 18,28 8,23 8,13" fill="rgba(0,212,255,0.1)" stroke="url(#lg1)" stroke-width="1"/>
            <circle cx="18" cy="18" r="4" fill="url(#lg1)"/>
            <defs>
              <linearGradient id="lg1" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#00D4FF"/>
                <stop offset="100%" stop-color="#7B2FFF"/>
              </linearGradient>
            </defs>
          </svg>
        </div>
        <div>
          <span class="block font-display text-lg font-black text-primary tracking-[3px] leading-none">NEXUS</span>
          <span class="block font-mono text-[8px] text-text-muted tracking-[2px] mt-0.5">INFINITY CORPORATION</span>
        </div>
      </div>
    <main class="min-h-screen flex flex-col items-center justify-center pb-24 px-6">

      <!-- Language toggle -->
      <div class="flex items-center gap-2 mb-8">
        <button id="btn-en" class="lang-btn font-mono text-[11px] tracking-[2px] uppercase px-4 py-1.5 rounded-full border transition-all bg-[rgba(0,212,255,0.12)] border-primary text-primary">EN</button>
        <button id="btn-es" class="lang-btn font-mono text-[11px] tracking-[2px] uppercase px-4 py-1.5 rounded-full border transition-all bg-transparent border-[rgba(0,212,255,0.2)] text-text-muted">ES</button>
      </div>

      <!-- Hero label -->
      <div class="inline-flex items-center gap-2.5 bg-[rgba(123,47,255,0.1)] border border-[rgba(123,47,255,0.3)] px-[18px] py-2 rounded-full mb-7 font-mono text-xs text-[#B088FF]">
        <span class="w-2 h-2 bg-accent2 rounded-full animate-pulse-dot"></span>
        <span class="t-en">Select your Nexus Infinity Platform</span>
        <span class="t-es hidden">Selecciona tu Plataforma Nexus Infinity</span>
      </div>

      <!-- Global Heading - Region Selector -->
      <div class="w-full max-w-[860px] mb-4" id="region-selector">
            <!-- Global Presence -->
    <div class="mb-8 pb-8 border-b border-[rgba(0,212,255,0.15)]">
      <h5 class="font-display text-[10px] tracking-[2px] text-primary mb-4 text-center">
        <span class="t-en">GLOBAL PRESENCE</span>
        <span class="t-es hidden">PRESENCIA GLOBAL</span>
      </h5>
    

        <!-- Region tab pills -->
        <div class="flex flex-wrap items-center justify-center gap-2" id="region-tabs">
          {regions.map((r, i) => (
            <button
              class="region-tab group font-mono text-[10px] tracking-[1.5px] uppercase px-3.5 py-1.5 rounded-full border border-[rgba(0,212,255,0.2)] text-text-muted bg-transparent hover:border-primary hover:text-primary transition-all duration-200 flex items-center gap-1"
              data-region={String(i)}
            >
              <span>{r.glob}</span>
              <span class="t-en ml-0.5">{r.labelEn}</span>
              <span class="t-es hidden ml-0.5">{r.labelEs}</span>
              <span class="region-chevron ml-1 text-[8px] opacity-60 inline-block transition-transform duration-200">▾</span>
            </button>
          ))}
        </div>
        
        <!-- Expandable countries panel -->
        <div
          id="region-panel"
          class="overflow-hidden transition-all duration-500"
          style="max-height:0;opacity:0;margin-top:0;"
        >
          <div class="bg-[rgba(0,0,0,0.35)] border border-[rgba(0,212,255,0.13)] rounded-xl p-4 mt-2">
            {regions.map((r, i) => (
              <div class="region-countries hidden grid grid-cols-3 gap-x-6 gap-y-2" data-region={String(i)}>
                {r.countries.map(c => (
                  <div class="flex items-center gap-2 text-[12px] text-text-muted min-w-0">
                    <span class="text-[15px] leading-none shrink-0">{c.flag}</span>
                    <span class="t-en truncate">{c.nameEn}</span>
                    <span class="t-es hidden truncate">{c.nameEs}</span>
                  </div>
                ))}
              </div>
            ))}
          </div>
        </div>
      </div>
      </div>

      <!-- Expandable Industries -->
        <!-- Industries Dropdown -->
      <div class="w-full max-w-[860px] my-3" id="industry-selector">

        <!-- Trigger button -->
        <div class="flex justify-center">
          <button
            id="industry-toggle"
            class="group inline-flex items-center gap-3 font-mono text-[11px] tracking-[2px] uppercase px-6 py-3 rounded-full border border-[rgba(0,212,255,0.4)] text-primary bg-[rgba(0,212,255,0.07)] hover:bg-[rgba(0,212,255,0.13)] hover:border-primary hover:shadow-[0_0_24px_rgba(0,212,255,0.25)] transition-all duration-300 shadow-[0_0_12px_rgba(0,212,255,0.1)]"
          >
            <span class="w-6 h-6 rounded-lg bg-[rgba(0,212,255,0.12)] border border-[rgba(0,212,255,0.25)] flex items-center justify-center text-[13px] shrink-0">🏢</span>
            <span class="t-en">Industries We Serve</span>
            <span class="t-es hidden">Industrias que Atendemos</span>
            <span id="industry-chevron" class="text-[9px] opacity-70 transition-transform duration-300 inline-block ml-1">▾</span>
          </button>
        </div>

        <!-- Expandable panel -->
        <div
          id="industry-panel"
          class="overflow-hidden transition-all duration-500"
          style="max-height:0;opacity:0;margin-top:0;"
        >
          <div class="bg-bg-card border border-[rgba(0,212,255,0.2)] rounded-2xl p-5 mt-3 shadow-[0_0_40px_rgba(0,212,255,0.06)]">

            <!-- Filter tabs -->
            <div class="flex flex-wrap items-center justify-center gap-2 mb-5">
              {[
                { key: 'all',  labelEn: 'All Industries', labelEs: 'Todas',      color: 'text-text-muted border-[rgba(0,212,255,0.2)]' },
                { key: 'crm',  labelEn: 'CRM',            labelEs: 'CRM',        color: 'text-primary   border-[rgba(0,212,255,0.35)]' },
                { key: 'erp',  labelEn: 'ERP',            labelEs: 'ERP',        color: 'text-[#B088FF] border-[rgba(123,47,255,0.35)]' },
                { key: 'both', labelEn: 'Both',           labelEs: 'Ambas',      color: 'text-accent2   border-[rgba(255,107,53,0.4)]' },
              ].map(f => (
                <button
                  class={`ind-filter font-mono text-[10px] tracking-[1.5px] uppercase px-3.5 py-1.5 rounded-full border bg-transparent transition-all duration-200 ${f.color}`}
                  data-filter={f.key}
                >
                  <span class="t-en">{f.labelEn}</span>
                  <span class="t-es hidden">{f.labelEs}</span>
                </button>
              ))}
            </div>

            <!-- Industry grid -->
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3" id="industry-grid">
              {industries.map(ind => (
                <div
                  class={`ind-card group relative flex flex-col gap-2 bg-bg-card rounded-xl p-3 overflow-hidden transition-all duration-300 cursor-default border ${
                    ind.platform === 'crm'  ? 'border-[rgba(0,212,255,0.15)]  hover:border-primary    hover:shadow-[0_0_28px_rgba(0,212,255,0.2)]' :
                    ind.platform === 'erp'  ? 'border-[rgba(123,47,255,0.15)] hover:border-[#B088FF]  hover:shadow-[0_0_28px_rgba(123,47,255,0.2)]' :
                                              'border-[rgba(0,255,179,0.12)]  hover:border-accent2    hover:shadow-[0_0_28px_rgba(0,255,179,0.15)]'
                  }`}
                  data-platform={ind.platform}
                >
                  <!-- Top accent line -->
                  <div class={`absolute top-0 left-0 right-0 h-[2px] ${
                    ind.platform === 'crm'  ? 'bg-gradient-to-r from-primary/60 to-transparent' :
                    ind.platform === 'erp'  ? 'bg-gradient-to-r from-[#B088FF]/60 to-transparent' :
                                              'bg-gradient-to-r from-accent2/60 to-transparent'
                  }`}></div>

                  <!-- Icon + badge row -->
                  <div class="flex items-center justify-between mt-1">
                    <div class={`w-9 h-9 rounded-lg flex items-center justify-center text-[18px] ${
                      ind.platform === 'crm'  ? 'bg-[rgba(0,212,255,0.1)]   border border-[rgba(0,212,255,0.2)]' :
                      ind.platform === 'erp'  ? 'bg-[rgba(123,47,255,0.1)] border border-[rgba(123,47,255,0.2)]' :
                                                'bg-[rgba(0,255,179,0.08)]  border border-[rgba(0,255,179,0.2)]'
                    }`}>{ind.icon}</div>
                    {ind.platform === 'crm' && (
                      <span class="font-mono text-[8px] tracking-[1.5px] uppercase px-2 py-0.5 rounded-full bg-[rgba(0,212,255,0.1)] border border-[rgba(0,212,255,0.3)] text-primary">CRM</span>
                    )}
                    {ind.platform === 'erp' && (
                      <span class="font-mono text-[8px] tracking-[1.5px] uppercase px-2 py-0.5 rounded-full bg-[rgba(123,47,255,0.1)] border border-[rgba(123,47,255,0.3)] text-[#B088FF]">ERP</span>
                    )}
                    {ind.platform === 'both' && (
                      <span class="font-mono text-[8px] tracking-[1.5px] uppercase px-2 py-0.5 rounded-full border border-[rgba(0,255,179,0.3)] text-accent2" style="background:rgba(0,255,179,0.08)">Both</span>
                    )}
                  </div>
                  <!-- Name -->
                  <p class="font-display text-[12px] font-bold text-white leading-tight">
                    <span class="t-en">{ind.nameEn}</span>
                    <span class="t-es hidden">{ind.nameEs}</span>
                  </p>
                  <!-- Desc -->
                  <p class="text-[10px] text-text-muted leading-[1.5]">
                    <span class="t-en">{ind.descEn}</span>
                    <span class="t-es hidden">{ind.descEs}</span>
                  </p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
      
      <!-- Heading -->
      <h1 class="font-display text-[clamp(28px,4vw,56px)] font-black leading-[1.1] text-white text-center mb-4 tracking-[-1px]">
        <span class="t-en">Which solution<br/><span class="gradient-text-brand">do you need today?</span></span>
        <span class="t-es hidden">¿Qué solución<br/><span class="gradient-text-brand">necesitas hoy?</span></span>
      </h1>
      <p class="text-[15px] sm:text-[17px] text-text-muted leading-[1.75] text-center max-w-[540px] mb-14">
        <span class="t-en">Choose the platform that best fits your business. Both powered by <strong class="text-primary">Artificial Intelligence</strong> and ready to scale.</span>  
        <span class="t-es hidden">Elige la plataforma que mejor se adapta a tu negocio. Ambas potenciadas con <strong class="text-primary">Inteligencia Artificial</strong> y listas para escalar.</span>
      </p>

      <!-- Selector Cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 w-full max-w-[860px]" id="product-selector">

        <!-- CRM Card -->
        <button
          id="card-crm"
          data-target="/crm"
          class="product-card group relative text-left bg-bg-card border border-[rgba(0,212,255,0.15)] rounded-2xl p-8 cursor-pointer transition-all duration-300 hover:border-primary hover:shadow-[0_0_40px_rgba(0,212,255,0.18)] focus:outline-none"
          aria-pressed="false"
        >
          <!-- Active ring overlay -->
          <div class="card-ring absolute inset-0 rounded-2xl border-2 border-primary opacity-0 transition-opacity duration-300 pointer-events-none shadow-[0_0_30px_rgba(0,212,255,0.35)]"></div>

          <!-- Selected badge -->
          <div class="card-badge absolute -top-3 left-6 bg-gradient-to-r from-primary to-secondary text-black text-[11px] font-bold px-3.5 py-0.5 rounded-full opacity-0 transition-opacity duration-300">
            <span class="t-en">✓ Selected</span>
            <span class="t-es hidden">✓ Seleccionado</span>
          </div>

          <!-- Icon -->
          <div class="w-14 h-14 rounded-2xl bg-[rgba(0,212,255,0.1)] border border-[rgba(0,212,255,0.25)] flex items-center justify-center text-2xl mb-5 transition-all duration-300 group-hover:bg-[rgba(0,212,255,0.18)] card-icon">
            💬
          </div>

          <!-- Label -->
          <div class="inline-flex items-center gap-1.5 font-mono text-[10px] tracking-[3px] text-primary uppercase bg-[rgba(0,212,255,0.08)] border border-[rgba(0,212,255,0.3)] px-3 py-1 rounded-full mb-3">
            <span class="w-1.5 h-1.5 bg-primary rounded-full animate-pulse-dot"></span>
            CRM
          </div>

          <h2 class="font-display text-[22px] sm:text-[26px] font-bold text-white mb-3 leading-tight">
            <span class="t-en">Multichannel CRM<br/><span class="text-primary">with AI</span></span>
            <span class="t-es hidden">CRM Multicanal<br/><span class="text-primary">con IA</span></span>
          </h2>

          <div class="text-[14px] text-text-muted leading-[1.75] mb-6">
            <p class="t-en mb-3">Manage all your communication channels — Facebook, Instagram, TikTok, WhatsApp and more — from a unified dashboard. AI Agents that attend, qualify and convert <strong class="text-text-base">24/7</strong> without human intervention.</p>
            <p class="t-es hidden mb-3">Gestiona todos tus canales de comunicación — desde un panel unificado. Agentes de IA que atienden, califican y convierten <strong class="text-text-base">24/7</strong> sin intervención humana.</p>
            
            <ul class="t-en hidden list-disc ml-6 space-y-1">
              <li>Finance & Accounting</li>
              <li>Inventory</li>
              <li>Sales</li>
              <li>Human Resources</li>
            </ul>
            <ul class="t-es hidden list-disc ml-6 space-y-1">
              <li>Finanzas y contabilidad</li>
              <li>Inventario</li>
              <li>Ventas</li>
              <li>Recursos Humanos</li>
            </ul>
          </div>

          <!-- Feature pills -->
          <ul class="flex flex-wrap gap-2 mb-7">
            {[
              { en: 'Omnichannel', es: 'Omnicanal' },
              { en: 'AI Agents',   es: 'Agentes IA' },
              { en: 'VoIP',        es: 'VoIP' },
              { en: 'Mobile App',  es: 'App Móvil' },
              { en: 'Automation',  es: 'Automatización' },
            ].map(f => (
              <li class="text-[11px] font-mono text-primary bg-[rgba(0,212,255,0.07)] border border-[rgba(0,212,255,0.2)] px-2.5 py-1 rounded-full">
                <span class="t-en">{f.en}</span><span class="t-es hidden">{f.es}</span>
              </li>
            ))}
          </ul>

          <!-- CTA -->
          <div class="card-cta flex items-center gap-2 text-[13px] font-semibold text-primary transition-all duration-300">
            <span class="t-en">Explore CRM</span>
            <span class="t-es hidden">Explorar CRM</span>
            <span class="translate-x-0 group-hover:translate-x-1 transition-transform duration-300">→</span>
          </div>
        </button>

        <!-- ERP Card -->
        <button
          id="card-erp"
          data-target="/erp"
          class="product-card group relative text-left bg-bg-card border border-[rgba(0,212,255,0.15)] rounded-2xl p-8 cursor-pointer transition-all duration-300 hover:border-secondary hover:shadow-[0_0_40px_rgba(123,47,255,0.18)] focus:outline-none"
          aria-pressed="false"
        >
          <!-- Active ring overlay -->
          <div class="card-ring absolute inset-0 rounded-2xl border-2 border-secondary opacity-0 transition-opacity duration-300 pointer-events-none shadow-[0_0_30px_rgba(123,47,255,0.35)]"></div>

          <!-- Selected badge -->
          <div class="card-badge absolute -top-3 left-6 bg-gradient-to-r from-secondary to-accent text-white text-[11px] font-bold px-3.5 py-0.5 rounded-full opacity-0 transition-opacity duration-300">
            <span class="t-en">✓ Selected</span>
            <span class="t-es hidden">✓ Seleccionado</span>
          </div>

          <!-- Icon -->
          <div class="w-14 h-14 rounded-2xl bg-[rgba(123,47,255,0.1)] border border-[rgba(123,47,255,0.25)] flex items-center justify-center text-2xl mb-5 transition-all duration-300 group-hover:bg-[rgba(123,47,255,0.18)] card-icon">
            ⚙️
          </div>

          <!-- Label -->
          <div class="inline-flex items-center gap-1.5 font-mono text-[10px] tracking-[3px] text-[#B088FF] uppercase bg-[rgba(123,47,255,0.08)] border border-[rgba(123,47,255,0.3)] px-3 py-1 rounded-full mb-3">
            <span class="w-1.5 h-1.5 bg-[#B088FF] rounded-full animate-pulse-dot"></span>
            ERP
          </div>

          <h2 class="font-display text-[22px] sm:text-[26px] font-bold text-white mb-3 leading-tight">
            <span class="t-en">Enterprise ERP<br/><span class="text-[#B088FF]">Intelligent</span></span>
            <span class="t-es hidden">ERP Empresarial<br/><span class="text-[#B088FF]">Inteligente</span></span>
          </h2>

          <div class="text-[14px] text-text-muted leading-[1.75] mb-6">
            <p class="t-en mb-3">Automate and centralize your entire business: inventory, finance, HR, procurement and production in one system. Real-time data-driven decisions with <strong class="text-text-base">integrated AI</strong>.</p>
            <p class="t-es hidden mb-3">Automatiza y centraliza la gestión de tu empresa: inventarios, finanzas, RRHH, compras y producción en un solo sistema. Decisiones basadas en datos en <strong class="text-text-base">tiempo real</strong> con IA integrada.</p>
            
            <ul class="t-en hidden list-disc ml-6 space-y-1">
              <li>Business Benefits</li>
              <li>More Efficient Operations</li>
              <li>Better Decision Making</li>
              <li>Effortless Scalability</li>
            </ul>
            <ul class="t-es hidden list-disc ml-6 space-y-1">
              <li>Beneficios Empresariales</li>
              <li>Operaciones más eficientes</li>
              <li>Mejor toma de decisiones</li>
              <li>Escalabilidad sin esfuerzo</li>
            </ul>
          </div>

          <!-- Feature pills -->
          <ul class="flex flex-wrap gap-2 mb-7">
            {[
              { en: 'Inventory',   es: 'Inventario' },
              { en: 'Finance',     es: 'Finanzas' },
              { en: 'HR',          es: 'RRHH' },
              { en: 'Procurement', es: 'Compras' },
              { en: 'Production',  es: 'Producción' },
            ].map(f => (
              <li class="text-[11px] font-mono text-[#B088FF] bg-[rgba(123,47,255,0.07)] border border-[rgba(123,47,255,0.2)] px-2.5 py-1 rounded-full">
                <span class="t-en">{f.en}</span><span class="t-es hidden">{f.es}</span>
              </li>
            ))}
          </ul>

          <!-- CTA -->
          <div class="card-cta flex items-center gap-2 text-[13px] font-semibold text-[#B088FF] transition-all duration-300">
            <span class="t-en">Explore ERP</span>
            <span class="t-es hidden">Explorar ERP</span>
            <span class="translate-x-0 group-hover:translate-x-1 transition-transform duration-300">→</span>
          </div>
        </button>

      </div>
      <!-- Proceed button (hidden until selection, desktop) -->
      <div id="proceed-wrapper" class="mt-10 transition-all duration-500 hidden md:block" style="opacity:0;transform:translateY(16px);pointer-events:none;">
        <a
          id="proceed-btn"
          href="#"
          class="btn-primary-glow inline-flex items-center gap-3 bg-gradient-to-br from-primary to-secondary text-white font-bold text-[15px] px-10 py-[15px] rounded-full border-none cursor-pointer no-underline shadow-glow-primary"
        >
          <span id="proceed-label-en" class="t-en">Continue →</span>
          <span id="proceed-label-es" class="t-es hidden">Continuar →</span>
        </a>
        <p class="text-center text-xs text-text-dim mt-3 font-mono">
          <span class="t-en">You can change your selection at any time</span>
          <span class="t-es hidden">Puedes cambiar tu selección en cualquier momento</span>
        </p>
      </div>

      <!-- Divider + compare note -->
      <div class="flex items-center gap-4 mt-10 w-full max-w-[860px]">
        <div class="flex-1 h-px bg-[rgba(0,212,255,0.1)]"></div>
        <span class="text-xs text-text-dim font-mono whitespace-nowrap">
          <span class="t-en">Not sure which to choose?</span>
          <span class="t-es hidden">¿No sabes cuál elegir?</span>
        </span>
        <div class="flex-1 h-px bg-[rgba(0,212,255,0.1)]"></div>
      </div>

      <p class="text-[13px] text-text-muted text-center mt-4 max-w-[480px]">
        <span class="t-en">Talk to a specialist and we'll help you find the ideal solution for your industry.</span>
        <span class="t-es hidden">Habla con un especialista y te ayudamos a encontrar la solución ideal para tu industria.</span>
        <a href="/demo-form" class="text-primary underline underline-offset-2 ml-1 hover:text-accent2 transition-colors">
          <span class="t-en">Get free advice →</span>
          <span class="t-es hidden">Solicitar asesoría gratis →</span>
        </a>
      </p>

    </main>

    <Footer />
  </div>
</BaseLayout>

<script>
  import { navigate } from 'astro:transitions/client';

  function initIndexPage() {
    // ── Shared state ─────────────────────────────────────────
    let currentLang: 'en' | 'es' = 'en';
    let selectedTarget: string | null = null;

    // ── Language toggle ───────────────────────────────────────
    const btnEn = document.getElementById('btn-en');
    const btnEs = document.getElementById('btn-es');
    if (!btnEn || !btnEs) return;

    function setLang(lang: 'en' | 'es') {
      const show = lang === 'en' ? '.t-en' : '.t-es';
      const hide = lang === 'en' ? '.t-es' : '.t-en';
      document.querySelectorAll<HTMLElement>(show).forEach(el => el.classList.remove('hidden'));
      document.querySelectorAll<HTMLElement>(hide).forEach(el => el.classList.add('hidden'));
      const active = 'bg-[rgba(0,212,255,0.12)] border-primary text-primary';
      const idle   = 'bg-transparent border-[rgba(0,212,255,0.2)] text-text-muted';
      const base   = 'lang-btn font-mono text-[11px] tracking-[2px] uppercase px-4 py-1.5 rounded-full border transition-all';
      if (lang === 'en') {
        btnEn!.className = `${base} ${active}`;
        btnEs!.className = `${base} ${idle}`;
      } else {
        btnEs!.className = `${base} ${active}`;
        btnEn!.className = `${base} ${idle}`;
      }
      localStorage.setItem('nxLang', lang);
      currentLang = lang;
      if (selectedTarget) updateProceedLabel(selectedTarget);
    }

    btnEn.addEventListener('click', () => setLang('en'));
    btnEs.addEventListener('click', () => setLang('es'));

    const saved = localStorage.getItem('nxLang') as 'en' | 'es' | null;
    setLang(saved === 'es' ? 'es' : 'en');

    // ── Product card selection ────────────────────────────────
    const cards = document.querySelectorAll<HTMLButtonElement>('.product-card');
    const proceedWrapper = document.getElementById('proceed-wrapper')!;
    const proceedBtn = document.getElementById('proceed-btn') as HTMLAnchorElement;
    const proceedLabelEn = document.getElementById('proceed-label-en')!;
    const proceedLabelEs = document.getElementById('proceed-label-es')!;

    const productNames: Record<string, { en: string; es: string }> = {
      '/crm': { en: 'Go to Multichannel CRM', es: 'Ir a CRM Multicanal' },
      '/erp': { en: 'Go to Enterprise ERP',   es: 'Ir a ERP Empresarial' },
    };

    function updateProceedLabel(target: string) {
      const names = productNames[target];
      proceedLabelEn.textContent = `${names.en} →`;
      proceedLabelEs.textContent = `${names.es} →`;
    }

    cards.forEach((card) => {
      card.addEventListener('click', () => {
        const target = card.dataset.target!;

        // On mobile (proceed button hidden) → show feedback then navigate
        if (window.innerWidth < 768) {
          cards.forEach((c) => {
            c.querySelector<HTMLElement>('.card-ring')!.style.opacity = '0';
            c.querySelector<HTMLElement>('.card-badge')!.style.opacity = '0';
          });
          card.querySelector<HTMLElement>('.card-ring')!.style.opacity = '1';
          card.querySelector<HTMLElement>('.card-badge')!.style.opacity = '1';
          card.classList.add('scale-[1.02]');
          setTimeout(() => {
            try {
              navigate(target);
            } catch {
              window.location.href = target;
            }
          }, 180);
          return;
        }

        // Deselect all
        cards.forEach((c) => {
          c.setAttribute('aria-pressed', 'false');
          c.querySelector<HTMLElement>('.card-ring')!.style.opacity = '0';
          c.querySelector<HTMLElement>('.card-badge')!.style.opacity = '0';
          c.classList.remove('scale-[1.02]');
        });

        // Select clicked card
        card.setAttribute('aria-pressed', 'true');
        card.querySelector<HTMLElement>('.card-ring')!.style.opacity = '1';
        card.querySelector<HTMLElement>('.card-badge')!.style.opacity = '1';
        card.classList.add('scale-[1.02]');

        // Update labels + hrefs
        selectedTarget = target;
        proceedBtn.setAttribute('href', target);
        updateProceedLabel(target);

        // Show desktop proceed wrapper
        proceedWrapper.style.opacity = '1';
        proceedWrapper.style.transform = 'translateY(0)';
        proceedWrapper.style.pointerEvents = 'auto';
      });
    });

    // Navigation handlers
    proceedBtn.addEventListener('click', (e) => {
      e.preventDefault();
      if (selectedTarget) navigate(selectedTarget);
    });

    // ── Industry dropdown ─────────────────────────────────────
    const industryToggle = document.getElementById('industry-toggle')!;
    const industryPanel  = document.getElementById('industry-panel')!;
    const industryChevron = document.getElementById('industry-chevron')!;
    const indFilters     = document.querySelectorAll<HTMLButtonElement>('.ind-filter');
    const indCards       = document.querySelectorAll<HTMLElement>('.ind-card');
    let industryOpen     = false;

    const IND_ACTIVE: Record<string, string[]> = {
      all:  ['bg-[rgba(0,212,255,0.1)]',   'border-primary',             'text-primary'],
      crm:  ['bg-[rgba(0,212,255,0.12)]',  'border-[rgba(0,212,255,0.5)]', 'text-primary'],
      erp:  ['bg-[rgba(123,47,255,0.12)]', 'border-[rgba(123,47,255,0.5)]','text-[#B088FF]'],
      both: ['bg-[rgba(255,107,53,0.1)]',  'border-[rgba(255,107,53,0.5)]','text-accent2'],
    };

    if (industryToggle) {
      industryToggle.addEventListener('click', () => {
        industryOpen = !industryOpen;
        if (industryOpen) {
          industryPanel.style.maxHeight = '800px';
          industryPanel.style.opacity   = '1';
          industryPanel.style.marginTop = '0';
          industryChevron.style.transform = 'rotate(180deg)';
        } else {
          industryPanel.style.maxHeight = '0';
          industryPanel.style.opacity   = '0';
          industryPanel.style.marginTop = '0';
          industryChevron.style.transform = 'rotate(0deg)';
        }
      });
    }

    // Activate 'all' filter by default
    function setIndFilter(key: string) {
      indFilters.forEach(btn => {
        const k = btn.dataset.filter!;
        if (k === key) {
          btn.classList.add(...IND_ACTIVE[k]);
        } else {
          btn.classList.remove(...Object.values(IND_ACTIVE).flat());
        }
      });
      indCards.forEach(card => {
        const p = card.dataset.platform!;
        if (key === 'all' || p === key) {
          card.classList.remove('hidden');
        } else {
          card.classList.add('hidden');
        }
      });
    }

    indFilters.forEach(btn => {
      btn.addEventListener('click', () => setIndFilter(btn.dataset.filter!));
    });

    setIndFilter('all');

    // ── Region selector ──────────────────────────────────────
    const regionTabs = document.querySelectorAll<HTMLButtonElement>('.region-tab');
    const regionPanel = document.getElementById('region-panel')!;
    const regionCountries = document.querySelectorAll<HTMLElement>('.region-countries');
    let openRegion: string | null = null;

    const TAB_ACTIVE = ['bg-[rgba(0,212,255,0.12)]', 'border-primary', 'text-primary'];
    const TAB_IDLE   = ['border-[rgba(0,212,255,0.2)]', 'text-text-muted', 'bg-transparent'];

    regionTabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const idx = tab.dataset.region!;

        if (openRegion === idx) {
          openRegion = null;
          regionPanel.style.maxHeight = '0';
          regionPanel.style.opacity = '0';
          regionPanel.style.marginTop = '0';
          regionCountries.forEach(el => el.classList.add('hidden'));
          regionTabs.forEach(t => {
            t.classList.remove(...TAB_ACTIVE);
            t.classList.add(...TAB_IDLE);
            t.querySelector<HTMLElement>('.region-chevron')!.style.transform = 'rotate(0deg)';
          });
        } else {
          openRegion = idx;
          regionTabs.forEach(t => {
            t.classList.remove(...TAB_ACTIVE);
            t.classList.add(...TAB_IDLE);
            t.querySelector<HTMLElement>('.region-chevron')!.style.transform = 'rotate(0deg)';
          });
          tab.classList.remove(...TAB_IDLE);
          tab.classList.add(...TAB_ACTIVE);
          tab.querySelector<HTMLElement>('.region-chevron')!.style.transform = 'rotate(180deg)';
          regionCountries.forEach(el => {
            if (el.dataset.region === idx) {
              el.classList.remove('hidden');
            } else {
              el.classList.add('hidden');
            }
          });
          regionPanel.style.maxHeight = '500px';
          regionPanel.style.opacity = '1';
          regionPanel.style.marginTop = '8px';
        }
      });
    });
  }

  // Run on initial load and after every View Transition navigation
  document.addEventListener('astro:page-load', initIndexPage);
</script>
