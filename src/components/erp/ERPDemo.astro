---
---

<section class="py-16 sm:py-[100px] relative bg-[rgba(7,15,30,0.5)]" id="erp-demo">
  <div class="max-w-[1280px] mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-[70px] items-center">

      <!-- Left -->
      <div>
        <div class="inline-flex items-center gap-2 font-mono text-[11px] tracking-[3px] text-primary uppercase bg-[rgba(0,212,255,0.08)] border border-[rgba(0,212,255,0.4)] px-4 py-1.5 rounded-full mb-5">
          <span class="w-1.5 h-1.5 bg-primary rounded-full animate-pulse-dot"></span>
          <span class="t-en">Ready to start?</span><span class="t-es hidden">¿Listo para empezar?</span>
        </div>
        <h2 class="font-display text-[clamp(32px,4vw,52px)] font-bold leading-[1.1] gradient-text mb-5">
          <span class="t-en">Request your<br/>Personalized Demo</span>
          <span class="t-es hidden">Solicita tu Demo<br/>Personalizada</span>
        </h2>
        <p class="text-lg text-text-muted leading-[1.7] max-w-[520px] mb-7">
          <span class="t-en">Book a 30-minute session. We'll show you the platform configured for your specific industry.</span>
          <span class="t-es hidden">Agenda una sesión de 30 minutos. Te mostramos la plataforma configurada para tu industria específica.</span>
        </p>
        <div class="flex flex-col gap-2.5">
          {[
            { en: 'No credit card required',         es: 'Sin tarjeta de crédito' },
            { en: '14-day free trial',               es: 'Prueba gratuita 14 días' },
            { en: 'Onboarding included at no cost',  es: 'Onboarding incluido sin costo' },
            { en: 'Go live in as little as 4 weeks', es: 'En producción en 4 semanas' },
          ].map(b => (
            <div class="flex items-center gap-2.5 text-sm text-text-muted">
              <span class="text-accent2 font-bold">✓</span>
              <span class="t-en">{b.en}</span>
              <span class="t-es hidden">{b.es}</span>
            </div>
          ))}
        </div>
        <a href="/" class="inline-flex items-center gap-2 mt-8 text-sm text-text-muted hover:text-primary transition-colors no-underline">
          <span>←</span>
          <span class="t-en">Back to CRM landing</span>
          <span class="t-es hidden">Volver al CRM</span>
        </a>
      </div>

      <!-- Right: Form -->
      <div class="bg-bg-card border border-[rgba(0,212,255,0.4)] rounded-2xl p-5 sm:p-8 shadow-glow-primary">
        <div class="font-display text-[17px] font-bold mb-5 text-center text-primary t-en">Schedule Your Free ERP Demo</div>
        <div class="font-display text-[17px] font-bold mb-5 text-center text-primary t-es hidden">Agenda tu Demo ERP Gratis</div>
        <div class="mb-3.5">
          <label class="block text-[11px] text-text-muted mb-1.5 font-mono t-en">Full name</label>
          <label class="block text-[11px] text-text-muted mb-1.5 font-mono t-es hidden">Nombre completo</label>
          <input type="text" placeholder="Juan García" class="w-full bg-bg-dark border border-[rgba(0,212,255,0.15)] rounded-lg px-3.5 py-2.5 text-text-base font-body text-[13px] transition-all focus:outline-none focus:border-primary focus:shadow-[0_0_0_3px_rgba(0,212,255,0.1)] placeholder:text-text-dim" />
        </div>
        <div class="mb-3.5">
          <label class="block text-[11px] text-text-muted mb-1.5 font-mono t-en">Company</label>
          <label class="block text-[11px] text-text-muted mb-1.5 font-mono t-es hidden">Empresa</label>
          <input type="text" placeholder="Acme Corp" class="w-full bg-bg-dark border border-[rgba(0,212,255,0.15)] rounded-lg px-3.5 py-2.5 text-text-base font-body text-[13px] transition-all focus:outline-none focus:border-primary focus:shadow-[0_0_0_3px_rgba(0,212,255,0.1)] placeholder:text-text-dim" />
        </div>
        <div class="mb-3.5">
          <label class="block text-[11px] text-text-muted mb-1.5 font-mono t-en">Work email</label>
          <label class="block text-[11px] text-text-muted mb-1.5 font-mono t-es hidden">Email corporativo</label>
          <input type="email" placeholder="juan@empresa.com" class="w-full bg-bg-dark border border-[rgba(0,212,255,0.15)] rounded-lg px-3.5 py-2.5 text-text-base font-body text-[13px] transition-all focus:outline-none focus:border-primary focus:shadow-[0_0_0_3px_rgba(0,212,255,0.1)] placeholder:text-text-dim" />
        </div>
        <div class="mb-3.5">
          <label class="block text-[11px] text-text-muted mb-1.5 font-mono t-en">Module of interest</label>
          <label class="block text-[11px] text-text-muted mb-1.5 font-mono t-es hidden">Módulo de interés</label>
          <select class="w-full bg-bg-dark border border-[rgba(0,212,255,0.15)] rounded-lg px-3.5 py-2.5 text-text-base font-body text-[13px] transition-all focus:outline-none focus:border-primary focus:shadow-[0_0_0_3px_rgba(0,212,255,0.1)]">
            <option value="">-- Select --</option>
            <option>Finance & Accounting / Finanzas</option>
            <option>Human Resources / RRHH</option>
            <option>Inventory & Warehouse / Inventario</option>
            <option>Procurement / Compras</option>
            <option>Manufacturing / Manufactura</option>
            <option>Projects / Proyectos</option>
            <option>Full Suite / Suite Completa</option>
          </select>
        </div>
        <button type="submit" class="w-full btn-primary-glow bg-gradient-to-br from-primary to-secondary text-white font-bold text-[15px] px-8 py-[14px] rounded-full border-none cursor-pointer shadow-glow-primary transition-all hover:-translate-y-0.5">
          <span class="t-en">🚀 Request My Demo</span>
          <span class="t-es hidden">🚀 Solicitar Mi Demo</span>
        </button>
      </div>

    </div>
  </div>
</section>
