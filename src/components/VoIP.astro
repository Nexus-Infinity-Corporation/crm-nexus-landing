---
---

<section class="py-[100px] relative" id="voip">
  <div class="max-w-[1280px] mx-auto px-6">
    <div class="text-center mb-14">
      <div class="inline-flex items-center gap-2 font-mono text-[11px] tracking-[3px] text-primary uppercase bg-[rgba(0,212,255,0.08)] border border-[rgba(0,212,255,0.4)] px-4 py-1.5 rounded-full mb-5">
        <span class="w-1.5 h-1.5 bg-primary rounded-full animate-pulse-dot"></span>
        📞 VoIP Integrado
      </div>
      <h2 class="font-display text-[clamp(32px,4vw,52px)] font-bold leading-[1.1] gradient-text mb-5">Llama directamente<br/>desde la App</h2>
      <p class="text-lg text-text-muted leading-[1.7] max-w-[600px] mx-auto">Sin número externo, sin costos adicionales. El cliente abre la app, toca "Llamar" y conecta con el agente correcto en segundos.</p>
    </div>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-[50px] items-start">
      <!-- Steps -->
      <div>
        <h3 class="font-display text-[19px] mb-[26px] text-primary">¿Cómo funciona?</h3>
        <div class="flex flex-col gap-5">
          {[
            { n: '1', title: 'Cliente toca "Llamar Soporte"', desc: 'Un solo tap abre la llamada VoIP con tecnología WebRTC desde la app móvil' },
            { n: '2', title: 'IA evalúa y enruta la llamada', desc: 'Analiza el historial y enruta al agente con más skills para el problema del cliente' },
            { n: '3', title: 'Conexión en segundos con contexto', desc: 'El agente ve TODO el historial antes de contestar. Zero tiempo en "¿Me da su nombre?"' },
            { n: '4', title: 'IA asiste al agente en tiempo real', desc: 'Agent Assist sugiere respuestas y transcribe la llamada automáticamente' },
          ].map(step => (
            <div class="flex gap-4 items-start">
              <div class="w-[38px] h-[38px] rounded-full flex-shrink-0 bg-gradient-to-br from-primary to-secondary flex items-center justify-center font-display font-bold text-[13px]">{step.n}</div>
              <div>
                <strong class="block mb-1.5 text-sm">{step.title}</strong>
                <p class="text-xs text-text-muted leading-[1.6]">{step.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Call UI mockup -->
      <div>
        <div class="bg-bg-card border border-[rgba(0,212,255,0.4)] rounded-2xl overflow-hidden shadow-glow-primary">
          <!-- Call Header -->
          <div class="px-5 py-[26px] text-center bg-gradient-to-b from-[rgba(0,212,255,0.05)] to-transparent border-b border-[rgba(0,212,255,0.15)]">
            <div class="relative w-[72px] h-[72px] rounded-full bg-gradient-to-br from-primary to-secondary flex items-center justify-center text-xl font-bold mx-auto mb-3.5">
              <span>ML</span>
              <div class="ripple-ring absolute inset-0 rounded-full border-2 border-[rgba(0,212,255,0.4)]"></div>
              <div class="ripple-ring-2 absolute -inset-[20%] rounded-full border-2 border-[rgba(0,212,255,0.4)]"></div>
              <div class="ripple-ring-3 absolute -inset-[40%] rounded-full border-2 border-[rgba(0,212,255,0.4)]"></div>
            </div>
            <div class="font-display text-lg font-bold">María López</div>
            <div class="text-xs text-accent2 mt-1.5">● Llamada activa · 02:34</div>
            <div class="font-mono text-[10px] text-text-dim mt-0.5">📱 Nexus VoIP HD · WebRTC</div>
          </div>

          <!-- Agent Assist -->
          <div class="px-[18px] py-3.5 border-b border-[rgba(0,212,255,0.15)]">
            <div class="font-mono text-[10px] text-primary mb-2.5 tracking-[1px]">🤖 Agent Assist — En vivo</div>
            <div class="bg-bg-dark rounded-lg px-2.5 py-2 text-[11px] text-text-muted leading-[1.5] mb-1.5">
              <span class="font-mono text-[9px] font-bold px-1 py-px rounded-sm bg-[rgba(0,212,255,0.15)] text-primary mr-1.5">Sugerencia</span>
              "El cliente preguntó por precios. Ofrece 15% descuento plan anual"
            </div>
            <div class="bg-bg-dark rounded-lg px-2.5 py-2 text-[11px] text-text-muted leading-[1.5]">
              <span class="font-mono text-[9px] font-bold px-1 py-px rounded-sm bg-[rgba(0,212,255,0.15)] text-primary mr-1.5">Transcripción</span>
              "...quería saber si tienen algún descuento disponible para contratar este mes..."
            </div>
          </div>

          <!-- Call Controls -->
          <div class="flex justify-center gap-[18px] px-[18px] py-[18px]">
            <button class="w-12 h-12 rounded-full border border-[rgba(0,212,255,0.15)] bg-bg-card2 text-lg cursor-pointer transition-all hover:scale-110">🔇</button>
            <button class="w-12 h-12 rounded-full border border-accent bg-[rgba(255,45,120,0.2)] text-lg cursor-pointer transition-all hover:scale-110">📵</button>
            <button class="w-12 h-12 rounded-full border border-[rgba(0,212,255,0.15)] bg-bg-card2 text-lg cursor-pointer transition-all hover:scale-110">🔊</button>
          </div>
        </div>

        <!-- Benefits -->
        <div class="flex flex-col gap-2.5 mt-[18px]">
          {[
            '💰 Sin costo de llamada para el cliente',
            '🎙️ Grabación automática + transcripción IA',
            '⭐ CSAT automático post-llamada',
            '🌐 Calidad HD · Tecnología WebRTC',
          ].map(benefit => (
            <div class="flex items-center gap-2.5 text-[13px] text-text-muted px-3 py-2.5 bg-bg-card border border-[rgba(0,212,255,0.15)] rounded-lg">{benefit}</div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
