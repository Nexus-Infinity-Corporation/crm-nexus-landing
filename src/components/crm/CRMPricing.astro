---
const plans = [
  {
    id: 'plan-quarterly',
    period_en: 'Quarterly', period_es: 'Trimestral',
    badge: null,
    price: 90,
    billing_en: '/quarter', billing_es: '/trimestre',
    desc_en: 'Get started fast with full platform access every 3 months.',
    desc_es: 'Empieza rápido con acceso completo a la plataforma cada 3 meses.',
    features_en: [
      '✓ Up to 5 active channels',
      '✓ 10,000 conversations/qtr.',
      '✓ Basic AI Agent',
      '✓ 5 users included',
      '✓ Mobile app included',
      '✓ Monthly reports',
    ],
    features_es: [
      '✓ Hasta 5 canales activos',
      '✓ 10,000 conversaciones/trim.',
      '✓ Agente IA Básico',
      '✓ 5 usuarios incluidos',
      '✓ App móvil incluida',
      '✓ Reportes mensuales',
    ],
    featured: false,
    cta_en: 'Start Quarterly', cta_es: 'Empezar Trimestral',
  },
  {
    id: 'plan-semiannual',
    period_en: 'Semi-Annual', period_es: 'Semestral',
    badge_en: '⭐ Most Popular', badge_es: '⭐ Más Popular',
    price: 180,
    billing_en: '/6 months', billing_es: '/semestre',
    desc_en: 'The perfect balance between commitment and flexibility for your team.',
    desc_es: 'El equilibrio perfecto entre compromiso y flexibilidad para tu equipo.',
    features_en: [
      '✓ Unlimited channels',
      '✓ 30,000 conversations/6mo.',
      '✓ Advanced AI Agent + VoIP',
      '✓ 15 users included',
      '✓ Real-time analytics',
      '✓ Priority support 24/7',
    ],
    features_es: [
      '✓ Canales ilimitados',
      '✓ 30,000 conversaciones/sem.',
      '✓ Agente IA Avanzado + VoIP',
      '✓ 15 usuarios incluidos',
      '✓ Analítica en tiempo real',
      '✓ Soporte prioritario 24/7',
    ],
    featured: true,
    cta_en: 'Start Now', cta_es: 'Comenzar Ahora',
  },
  {
    id: 'plan-annual',
    period_en: 'Annual', period_es: 'Anual',
    badge: null,
    price: 290,
    billing_en: '/year', billing_es: '/año',
    desc_en: 'Maximum savings and early access to new features all year long.',
    desc_es: 'Máximo ahorro y acceso anticipado a nuevas funciones todo el año.',
    features_en: [
      '✓ Everything in Semi-Annual',
      '✓ Unlimited conversations',
      '✓ Unlimited AI Agents',
      '✓ Unlimited users',
      '✓ Guaranteed SLA 99.9%',
      '✓ Dedicated account manager',
    ],
    features_es: [
      '✓ Todo del plan Semestral',
      '✓ Conversaciones ilimitadas',
      '✓ Agentes IA ilimitados',
      '✓ Usuarios ilimitados',
      '✓ SLA garantizado 99.9%',
      '✓ Gerente de cuenta dedicado',
    ],
    featured: false,
    cta_en: 'Start Annual', cta_es: 'Empezar Anual',
  },
];
---

<section class="py-16 sm:py-[100px] relative" id="pricing">
  <div class="max-w-[1280px] mx-auto px-6">

    <!-- Header -->
    <div class="text-center mb-12 sm:mb-16">
      <div class="inline-flex items-center gap-2 font-mono text-[11px] tracking-[3px] text-primary uppercase bg-[rgba(0,212,255,0.08)] border border-[rgba(0,212,255,0.4)] px-4 py-1.5 rounded-full mb-5">
        <span class="w-1.5 h-1.5 bg-primary rounded-full animate-pulse-dot"></span>
        <span class="t-en">Plans &amp; Pricing</span>
        <span class="t-es hidden">Planes &amp; Precios</span>
      </div>
      <h2 class="font-display text-[clamp(32px,4vw,52px)] font-bold leading-[1.1] gradient-text mb-4">
        <span class="t-en">Choose your billing cycle</span>
        <span class="t-es hidden">Elige tu ciclo de facturación</span>
      </h2>
      <p class="text-[15px] text-text-muted max-w-[480px] mx-auto leading-[1.7]">
        <span class="t-en">No hidden fees. Change or cancel anytime.</span>
        <span class="t-es hidden">Sin costos ocultos. Cambia o cancela cuando quieras.</span>
      </p>
    </div>

    <!-- Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 items-start">
      {plans.map(plan => (
        <div class={`relative bg-bg-card rounded-2xl p-7 transition-all ${plan.featured ? 'border border-primary shadow-glow-primary md:scale-[1.03] hover:border-[rgba(0,212,255,0.6)]' : 'border border-[rgba(0,212,255,0.15)] hover:border-[rgba(0,212,255,0.4)]'}`}>
          {(plan.badge_en || plan.badge) && (
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-gradient-to-r from-primary to-secondary text-black text-[11px] font-bold px-3.5 py-0.5 rounded-full whitespace-nowrap">
              <span class="t-en">{plan.badge_en || plan.badge}</span>
              <span class="t-es hidden">{plan.badge_es || plan.badge}</span>
            </div>
          )}

          <div class={`font-display text-xs font-bold tracking-[2px] uppercase mb-2.5 ${plan.featured ? 'text-primary' : 'text-text-muted'}`}>
            <span class="t-en">{plan.period_en}</span>
            <span class="t-es hidden">{plan.period_es}</span>
          </div>

          <div class="mb-1 flex items-baseline gap-0.5">
            <span class="text-lg text-text-muted align-top mt-1.5 inline-block">$</span>
            <span class="font-display text-[44px] font-black leading-none">{plan.price}</span>
            <span class="text-[13px] text-text-muted ml-0.5">
              <span class="t-en">{plan.billing_en}</span>
              <span class="t-es hidden">{plan.billing_es}</span>
            </span>
          </div>

          <p class="text-xs text-text-muted my-3 leading-[1.6]">
            <span class="t-en">{plan.desc_en}</span>
            <span class="t-es hidden">{plan.desc_es}</span>
          </p>

          <ul class="list-none flex flex-col gap-0 mb-6">
            {plan.features_en.map((f, idx) => (
              <li class="text-[13px] text-text-muted py-1.5 border-b border-[rgba(0,212,255,0.15)]">
                <span class="t-en">{f}</span>
                <span class="t-es hidden">{plan.features_es[idx]}</span>
              </li>
            ))}
          </ul>

          <a
            href="#crm-demo"
            class={`flex items-center justify-center gap-2 font-bold text-[15px] px-8 py-[13px] rounded-full no-underline transition-all hover:-translate-y-0.5 ${plan.featured ? 'btn-primary-glow bg-gradient-to-br from-primary to-secondary text-white border-none shadow-glow-primary' : 'bg-transparent text-primary border border-[rgba(0,212,255,0.4)] hover:bg-[rgba(0,212,255,0.08)]'}`}
          >
            <span class="t-en">{plan.cta_en}</span>
            <span class="t-es hidden">{plan.cta_es}</span>
          </a>
        </div>
      ))}
    </div>

    <!-- Footer note -->
    <p class="text-center text-[12px] text-text-dim mt-8 font-mono">
      <span class="t-en">All plans include a 14-day free trial &middot; No credit card required</span>
      <span class="t-es hidden">Todos los planes incluyen prueba gratuita de 14 días · Sin tarjeta de crédito</span>
    </p>

  </div>
</section>
