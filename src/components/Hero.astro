<section class="hero min-h-screen pt-[120px] flex flex-col relative overflow-hidden" id="home">
  <div class="max-w-[1280px] mx-auto px-6 w-full">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-[60px] items-center py-[60px]">
      <!-- Left Content -->
      <div>
        <div class="inline-flex items-center gap-2.5 bg-[rgba(123,47,255,0.1)] border border-[rgba(123,47,255,0.3)] px-[18px] py-2 rounded-full mb-7 font-mono text-xs text-[#B088FF]">
          <span class="w-2 h-2 bg-accent2 rounded-full animate-pulse-dot"></span>
          <span>IA Generativa + Automatización 2025</span>
        </div>
        <h1 class="font-display text-[clamp(32px,4vw,60px)] font-black leading-[1.08] text-white mb-6 tracking-[-1px]">
          Conecta, Automatiza<br/>
          <span class="gradient-text-brand">y Domina</span><br/>
          todos tus canales
        </h1>
        <p class="text-[17px] text-text-muted leading-[1.75] mb-9 max-w-[520px]">
          CRM Multicanal potenciado con Inteligencia Artificial. Gestiona Facebook, Instagram, TikTok, App Móvil y más desde una sola plataforma. Agentes IA que trabajan <strong class="text-primary">24/7</strong> sin descanso.
        </p>
        <div class="flex gap-4 flex-wrap mb-12">
          <a href="#demo" class="btn-primary-glow inline-flex items-center gap-2.5 bg-gradient-to-br from-primary to-secondary text-white font-bold text-[15px] px-8 py-[14px] rounded-full border-none cursor-pointer no-underline shadow-glow-primary">
            <span class="relative z-10">🚀 Solicitar Demo Gratis</span>
          </a>
          <a href="#platform" class="inline-flex items-center gap-2.5 bg-transparent text-primary font-semibold text-[15px] px-8 py-[13px] rounded-full border border-[rgba(0,212,255,0.4)] cursor-pointer no-underline transition-all hover:bg-[rgba(0,212,255,0.08)] hover:translate-y-[-2px] hover:shadow-glow-primary">
            ▶ Ver en Acción
          </a>
        </div>
        <!-- Stats -->
        <div id="hero-stats" class="flex items-center gap-6 flex-wrap">
          <div class="text-center">
            <div class="flex items-baseline">
              <span class="font-display text-[28px] font-bold text-primary leading-none stat-num" data-target="500">0</span>
              <span class="font-display text-lg text-text-muted">+</span>
            </div>
            <span class="block text-xs text-text-dim mt-1 font-mono">Empresas</span>
          </div>
          <div class="w-px h-10 bg-[rgba(0,212,255,0.15)]"></div>
          <div class="text-center">
            <div class="flex items-baseline">
              <span class="font-display text-[28px] font-bold text-primary leading-none stat-num" data-target="10">0</span>
              <span class="font-display text-lg text-text-muted">M+</span>
            </div>
            <span class="block text-xs text-text-dim mt-1 font-mono">Mensajes/mes</span>
          </div>
          <div class="w-px h-10 bg-[rgba(0,212,255,0.15)]"></div>
          <div class="text-center">
            <div class="flex items-baseline">
              <span class="font-display text-[28px] font-bold text-primary leading-none stat-num" data-target="99">0</span>
              <span class="font-display text-lg text-text-muted">%</span>
            </div>
            <span class="block text-xs text-text-dim mt-1 font-mono">Uptime</span>
          </div>
          <div class="w-px h-10 bg-[rgba(0,212,255,0.15)]"></div>
          <div class="text-center">
            <div class="flex items-baseline">
              <span class="font-display text-[28px] font-bold text-primary leading-none stat-num" data-target="4">0</span>
              <span class="font-display text-lg text-text-muted">.9★</span>
            </div>
            <span class="block text-xs text-text-dim mt-1 font-mono">Rating</span>
          </div>
        </div>
      </div>

      <!-- Right Visual -->
      <div class="relative flex justify-center items-center h-[580px]">
        <!-- Phone Frame -->
        <div class="relative z-10">
          <div class="animate-float w-64 h-[510px] bg-bg-card2 border-2 border-[rgba(0,212,255,0.3)] rounded-[36px] p-3.5 shadow-[0_40px_80px_rgba(0,0,0,0.6),0_0_30px_rgba(0,212,255,0.4)]">
            <div class="w-20 h-[22px] bg-bg-dark rounded-b-2xl mx-auto mb-2.5"></div>
            <div class="bg-bg-dark rounded-3xl h-[calc(100%-40px)] overflow-hidden flex flex-col">
              <div class="flex items-center gap-1.5 px-3.5 py-2.5 bg-bg-card border-b border-[rgba(0,212,255,0.15)] text-xs font-semibold">
                <span class="font-display text-xs text-primary font-black">N∞</span>
                <span class="text-text-muted">Nexus App</span>
                <div class="ml-auto flex items-center gap-1 text-[10px] text-accent2">
                  <span class="w-1.5 h-1.5 bg-accent2 rounded-full animate-pulse-dot"></span> En línea
                </div>
              </div>
              <div class="flex-1 p-3 flex flex-col gap-2.5 overflow-hidden">
                <div class="flex gap-1.5 items-end">
                  <div class="w-6 h-6 rounded-full bg-gradient-to-br from-primary to-secondary flex items-center justify-center text-[8px] font-bold flex-shrink-0">IA</div>
                  <div class="max-w-[150px] px-[11px] py-2 rounded-2xl text-[11px] leading-[1.5] bg-bg-card2 border border-[rgba(0,212,255,0.15)] rounded-bl-sm">Hola! Soy tu agente Nexus IA 🤖 ¿En qué puedo ayudarte?</div>
                </div>
                <div class="flex flex-row-reverse gap-1.5 items-end">
                  <div class="max-w-[150px] px-[11px] py-2 rounded-2xl text-[11px] leading-[1.5] bg-gradient-to-br from-primary to-secondary rounded-br-sm">Necesito info sobre mis pedidos</div>
                </div>
                <div class="flex gap-1.5 items-end">
                  <div class="w-6 h-6 rounded-full bg-gradient-to-br from-primary to-secondary flex items-center justify-center text-[8px] font-bold flex-shrink-0">IA</div>
                  <div id="typing-bub" class="max-w-[150px] px-[14px] py-3 rounded-2xl bg-bg-card2 border border-[rgba(0,212,255,0.15)] rounded-bl-sm flex gap-1 items-center">
                    <span class="w-[5px] h-[5px] bg-text-muted rounded-full t-dot"></span>
                    <span class="w-[5px] h-[5px] bg-text-muted rounded-full t-dot"></span>
                    <span class="w-[5px] h-[5px] bg-text-muted rounded-full t-dot"></span>
                  </div>
                </div>
              </div>
              <div class="px-3 pb-2">
                <button class="w-full py-2 bg-gradient-to-br from-[#1a3a2a] to-[#0a2a1a] border border-[rgba(0,255,150,0.3)] rounded-lg text-accent2 text-[11px] cursor-pointer font-body">📞 Llamar a Soporte</button>
              </div>
              <div class="px-5 py-2.5 flex justify-between border-t border-[rgba(0,212,255,0.15)] text-base">
                <span>🏠</span><span>💬</span><span>📊</span><span>👤</span>
              </div>
            </div>
          </div>
        </div>
        <!-- Glow -->
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-80 h-80 bg-[radial-gradient(circle,rgba(0,212,255,0.15)_0%,transparent_70%)] rounded-full z-[1]"></div>
        <!-- Floating Cards -->
        <div class="animate-float absolute top-[30px] right-[-10px] z-[3] flex items-center gap-2.5 bg-[rgba(7,15,30,0.95)] border border-[rgba(0,212,255,0.4)] rounded-xl px-4 py-3 backdrop-blur-lg shadow-[0_8px_32px_rgba(0,0,0,0.4)] whitespace-nowrap">
          <span class="text-xl">🤖</span>
          <div>
            <div class="text-[11px] text-text-muted font-mono">Agente IA Activo</div>
            <div class="text-[13px] font-bold text-accent2 mt-0.5">1,247 chats hoy</div>
          </div>
        </div>
        <div class="animate-float-2 absolute top-[170px] left-[-30px] z-[3] hidden sm:flex items-center gap-2.5 bg-[rgba(7,15,30,0.95)] border border-[rgba(0,212,255,0.4)] rounded-xl px-4 py-3 backdrop-blur-lg shadow-[0_8px_32px_rgba(0,0,0,0.4)] whitespace-nowrap">
          <span class="text-xl">⚡</span>
          <div>
            <div class="text-[11px] text-text-muted font-mono">Resolución IA</div>
            <div class="text-[13px] font-bold text-primary mt-0.5">84% automático</div>
          </div>
        </div>
        <div class="animate-float-3 absolute bottom-[130px] right-[-20px] z-[3] flex items-center gap-2.5 bg-[rgba(7,15,30,0.95)] border border-[rgba(0,212,255,0.4)] rounded-xl px-4 py-3 backdrop-blur-lg shadow-[0_8px_32px_rgba(0,0,0,0.4)] whitespace-nowrap">
          <span class="text-xl">📞</span>
          <div>
            <div class="text-[11px] text-text-muted font-mono">VoIP Activo</div>
            <div class="text-[13px] font-bold text-secondary mt-0.5">23 llamadas</div>
          </div>
        </div>
        <div class="animate-float-4 absolute bottom-[50px] left-[-10px] z-[3] hidden sm:flex items-center gap-2 bg-[rgba(7,15,30,0.95)] border border-[rgba(0,212,255,0.4)] rounded-xl px-4 py-3 backdrop-blur-lg shadow-[0_8px_32px_rgba(0,0,0,0.4)] text-[13px] text-text-muted">
          <span>📘</span><span>📸</span><span>🎵</span><span>📱</span><span class="text-[11px]">+2 más</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Logos Bar -->
  <div class="bg-[rgba(7,15,30,0.8)] border-t border-b border-[rgba(0,212,255,0.15)] py-6">
    <div class="max-w-[1280px] mx-auto px-6">
      <p class="text-center text-[11px] text-text-dim font-mono tracking-[2px] mb-4">Con la confianza de líderes de la industria</p>
      <div class="overflow-hidden">
        <div class="animate-marquee flex gap-[60px] w-max">
          {['TechCorp','RetailMax','BancoPlus','AutoGroup','MediCare','EduGlobal','InsureTech','FastBrand','TechCorp','RetailMax','BancoPlus','AutoGroup','MediCare','EduGlobal','InsureTech','FastBrand'].map(brand => (
            <span class="font-display text-[13px] font-bold text-text-dim tracking-[2px] flex-shrink-0">{brand}</span>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Counter animation
  function animateCounters() {
    document.querySelectorAll<HTMLElement>('.stat-num').forEach(el => {
      const target = parseInt(el.dataset.target || '0');
      let cur = 0;
      const step = target / 50;
      const t = setInterval(() => {
        cur += step;
        if (cur >= target) { el.textContent = String(target); clearInterval(t); }
        else el.textContent = String(Math.floor(cur));
      }, 30);
    });
  }

  const statsEl = document.getElementById('hero-stats');
  if (statsEl) {
    const io = new IntersectionObserver(entries => {
      entries.forEach(e => { if (e.isIntersecting) { animateCounters(); io.disconnect(); } });
    }, { threshold: 0.1 });
    io.observe(statsEl);
  }

  // Typing loop
  function typingLoop() {
    const b = document.getElementById('typing-bub');
    if (!b) return;
    setTimeout(() => {
      b.innerHTML = 'Con gusto! Tienes 3 pedidos en camino 📦';
      b.className = 'max-w-[160px] px-[11px] py-2 rounded-2xl text-[10px] leading-relaxed bg-bg-card2 border border-[rgba(0,212,255,0.15)] rounded-bl-sm';
      setTimeout(() => {
        b.innerHTML = '<span class="w-[5px] h-[5px] bg-text-muted rounded-full t-dot"></span><span class="w-[5px] h-[5px] bg-text-muted rounded-full t-dot"></span><span class="w-[5px] h-[5px] bg-text-muted rounded-full t-dot"></span>';
        b.className = 'max-w-[150px] px-[14px] py-3 rounded-2xl bg-bg-card2 border border-[rgba(0,212,255,0.15)] rounded-bl-sm flex gap-1 items-center';
        typingLoop();
      }, 4000);
    }, 2500);
  }
  typingLoop();
</script>
