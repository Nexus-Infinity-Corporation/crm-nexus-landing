        <!--
          Hamburger <label> — clicking this toggles #nav-cb.
          The three bars animate to an ✕ via the <style> block below
          (CSS ~ + descendant combinators reach these spans from #nav-cb).
        -->
        <label for="nav-cb" class="lg:hidden flex flex-col justify-center gap-[5px] cursor-pointer p-1 w-8 h-8" aria-label="Toggle menu">
          <span data-bar="1" class="block w-6 h-0.5 bg-primary rounded-full transition-all duration-300 origin-center"></span>
          <span data-bar="2" class="block w-6 h-0.5 bg-primary rounded-full transition-all duration-300"></span>
          <span data-bar="3" class="block w-6 h-0.5 bg-primary rounded-full transition-all duration-300 origin-center"></span>
        </label>
      </div>
    </div>
  </div>
</nav>

<!--
  Mobile menu.
  - "hidden"             → display:none by default.
  - "peer-checked/nav:flex" → display:flex when #nav-cb is checked.
  - "lg:hidden"          → never shows on large screens even if somehow checked.
  This works because <input#nav-cb class="peer/nav"> is a preceding sibling of this div.
-->
<div class="hidden peer-checked/nav:flex lg:hidden fixed top-[73px] left-0 right-0 z-[999] bg-[rgba(3,8,16,0.98)] border-b border-[rgba(0,212,255,0.15)] backdrop-blur-xl px-6 py-4 flex-col gap-1">
  <a href="#platform" class="mobile-nav-link text-text-muted py-3 border-b border-[rgba(0,212,255,0.1)] hover:text-primary transition-colors">
    <span class="t-en">Platform</span><span class="t-es hidden">Plataforma</span>
  </a>
  <a href="#channels" class="mobile-nav-link text-text-muted py-3 border-b border-[rgba(0,212,255,0.1)] hover:text-primary transition-colors">
    <span class="t-en">Channels</span><span class="t-es hidden">Canales</span>
  </a>
  <a href="#mobile"   class="mobile-nav-link text-text-muted py-3 border-b border-[rgba(0,212,255,0.1)] hover:text-primary transition-colors">
    <span class="t-en">Mobile App</span><span class="t-es hidden">App Móvil</span>
  </a>
  <a href="#ai-agent" class="mobile-nav-link text-text-muted py-3 border-b border-[rgba(0,212,255,0.1)] hover:text-primary transition-colors">
    <span class="t-en">AI 24/7</span><span class="t-es hidden">IA 24/7</span>
  </a>
  <a href="#analytics" class="mobile-nav-link text-text-muted py-3 border-b border-[rgba(0,212,255,0.1)] hover:text-primary transition-colors">
    <span class="t-en">Analytics</span><span class="t-es hidden">Analítica</span>
  </a>
  <a href="#pricing"  class="mobile-nav-link text-text-muted py-3 border-b border-[rgba(0,212,255,0.1)] hover:text-primary transition-colors">
    <span class="t-en">Pricing</span><span class="t-es hidden">Precios</span>
  </a>
  <a href="#demo" class="mobile-nav-link mt-3 btn-primary-glow flex items-center justify-center bg-gradient-to-br from-primary to-secondary text-white font-bold text-[13px] px-5 py-3 rounded-full no-underline shadow-glow-primary">
    <span class="t-en">🚀 Request a Meeting</span>
    <span class="t-es hidden">🚀 Solicitar Reunión</span>
  </a>
</div>

<!--
  Hamburger → ✕ animation.
  Uses "#nav-cb:checked ~ nav [data-bar]" because the spans are NESTED inside
  <nav> (not direct siblings of #nav-cb), so Tailwind peer-checked can't reach them.
  The CSS ~ sibling combinator selects <nav>, then the space selector drills into it.
-->
<style>
  #nav-cb:checked ~ nav [data-bar="1"] {
    transform: translateY(6.5px) rotate(45deg);
  }
  #nav-cb:checked ~ nav [data-bar="2"] {
    opacity: 0;
    transform: scaleX(0);
  }
  #nav-cb:checked ~ nav [data-bar="3"] {
    transform: translateY(-6.5px) rotate(-45deg);
  }
</style>

<script>
  // Darken navbar on scroll
  window.addEventListener('scroll', () => {
    const navbar = document.getElementById('navbar');
    if (navbar) {
      navbar.classList.toggle('bg-[rgba(3,8,16,0.97)]', window.scrollY > 50);
      navbar.classList.toggle('shadow-[0_4px_30px_rgba(0,0,0,0.5)]', window.scrollY > 50);
    }
  });

  // Close mobile menu (uncheck the peer checkbox) when a nav link is tapped
  document.querySelectorAll<HTMLAnchorElement>('.mobile-nav-link').forEach(link => {
    link.addEventListener('click', () => {
      (document.getElementById('nav-cb') as HTMLInputElement).checked = false;
    });
  });
</script>
