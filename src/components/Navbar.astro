<!--
  Peer checkbox: placed BEFORE <nav> and the mobile menu <div> so that
  both can respond to peer-checked via the CSS ~ sibling combinator.
  The <label for="nav-cb"> inside the nav toggles it on tap/click.
-->
<input type="checkbox" id="nav-cb" class="peer/nav hidden" />

<nav id="navbar" class="fixed top-0 left-0 right-0 z-[1000] py-4 bg-[rgba(3,8,16,0.85)] backdrop-blur-xl border-b border-[rgba(0,212,255,0.15)] transition-all duration-300">
  <div class="max-w-[1280px] mx-auto px-6">
    <div class="flex items-center gap-10">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 no-underline">
        <div class="animate-float">
          <svg width="36" height="36" viewBox="0 0 36 36">
            <polygon points="18,2 34,10 34,26 18,34 2,26 2,10" fill="none" stroke="url(#lg1)" stroke-width="2"/>
            <polygon points="18,8 28,13 28,23 18,28 8,23 8,13" fill="rgba(0,212,255,0.1)" stroke="url(#lg1)" stroke-width="1"/>
            <circle cx="18" cy="18" r="4" fill="url(#lg1)"/>
            <defs>
              <linearGradient id="lg1" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#00D4FF"/>
                <stop offset="100%" stop-color="#7B2FFF"/>
              </linearGradient>
            </defs>
          </svg>
        </div>
        <div>
          <span class="block font-display text-lg font-black text-primary tracking-[3px] leading-none">NEXUS</span>
          <span class="block font-mono text-[8px] text-text-muted tracking-[2px] mt-0.5">INFINITY CORPORATION</span>
        </div>
      </a>

      <!-- Nav Links (desktop only) -->
      <ul class="hidden lg:flex list-none gap-2 ml-auto">
        <li><a href="#platform" class="flex items-center gap-1 text-text-muted no-underline text-sm px-3.5 py-2 rounded-lg transition-all hover:text-primary hover:bg-[rgba(0,212,255,0.06)]">
          <span class="t-en">Platform</span><span class="t-es hidden">Plataforma</span>
        </a></li>
        <li class="relative has-dropdown">
          <a href="#channels" class="flex items-center gap-1 text-text-muted no-underline text-sm px-3.5 py-2 rounded-lg transition-all hover:text-primary hover:bg-[rgba(0,212,255,0.06)]">
            <span class="t-en">Channels ▾</span><span class="t-es hidden">Canales ▾</span>
          </a>
          <div class="dropdown-menu absolute top-[calc(100%+10px)] left-1/2 bg-bg-card2 border border-[rgba(0,212,255,0.15)] rounded-lg p-2 min-w-[200px] shadow-[0_20px_40px_rgba(0,0,0,0.5)]">
            <a href="#channels" class="flex items-center gap-2.5 px-3.5 py-2.5 rounded-md text-sm text-text-muted hover:text-primary hover:bg-[rgba(0,212,255,0.06)] transition-all"><span>📘</span> Facebook & Instagram</a>
            <a href="#channels" class="flex items-center gap-2.5 px-3.5 py-2.5 rounded-md text-sm text-text-muted hover:text-primary hover:bg-[rgba(0,212,255,0.06)] transition-all"><span>🎵</span> TikTok</a>
            <a href="#mobile" class="flex items-center gap-2.5 px-3.5 py-2.5 rounded-md text-sm text-text-muted hover:text-primary hover:bg-[rgba(0,212,255,0.06)] transition-all"><span>📱</span> <span class="t-en">Mobile App</span><span class="t-es hidden">App Móvil</span></a>
            <a href="#channels" class="flex items-center gap-2.5 px-3.5 py-2.5 rounded-md text-sm text-text-muted hover:text-primary hover:bg-[rgba(0,212,255,0.06)] transition-all"><span>💬</span> WhatsApp</a>
          </div>
        </li>
        <li><a href="#mobile" class="flex items-center gap-1 text-text-muted no-underline text-sm px-3.5 py-2 rounded-lg transition-all hover:text-primary hover:bg-[rgba(0,212,255,0.06)]">
          <span class="t-en">Mobile App</span><span class="t-es hidden">App Móvil</span>
        </a></li>
        <li><a href="#ai-agent" class="flex items-center gap-1 text-text-muted no-underline text-sm px-3.5 py-2 rounded-lg transition-all hover:text-primary hover:bg-[rgba(0,212,255,0.06)]">
          <span class="t-en">AI 24/7</span><span class="t-es hidden">IA 24/7</span>
        </a></li>
        <li><a href="#analytics" class="flex items-center gap-1 text-text-muted no-underline text-sm px-3.5 py-2 rounded-lg transition-all hover:text-primary hover:bg-[rgba(0,212,255,0.06)]">
          <span class="t-en">Analytics</span><span class="t-es hidden">Analítica</span>
