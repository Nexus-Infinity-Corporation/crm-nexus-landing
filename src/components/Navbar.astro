      <!-- CTA Buttons + Hamburger -->
      <div class="flex items-center gap-2.5 ml-auto lg:ml-0">
        <!-- Language toggle (only shown on CRM/ERP pages) -->
        <div id="lang-toggle" class="hidden items-center gap-1.5">
          <button id="btn-en" class="lang-btn font-mono text-[11px] tracking-[2px] uppercase px-3 py-1 rounded-full border transition-all bg-[rgba(0,212,255,0.12)] border-primary text-primary">EN</button>
          <button id="btn-es" class="lang-btn font-mono text-[11px] tracking-[2px] uppercase px-3 py-1 rounded-full border transition-all bg-transparent border-[rgba(0,212,255,0.2)] text-text-muted">ES</button>
        </div>
        <!-- <a href="#demo" class="hidden sm:inline-flex items-center gap-2.5 bg-transparent text-primary font-semibold text-[13px] px-5 py-2.5 rounded-full border border-[rgba(0,212,255,0.4)] cursor-pointer no-underline transition-all hover:bg-[rgba(0,212,255,0.08)] hover:translate-y-[-2px] hover:shadow-glow-primary">
          <span class="t-en">View Demo</span><span class="t-es hidden">Ver Demo</span>
        </a> -->
        <a href="#demo" class="btn-primary-glow inline-flex items-center gap-2.5 bg-gradient-to-br from-primary to-secondary text-white font-bold text-[13px] px-5 py-2.5 rounded-full border-none cursor-pointer no-underline shadow-glow-primary">
          <span class="relative z-10 t-en">Start Free</span>
          <span class="relative z-10 t-es hidden">Empezar Gratis</span>
