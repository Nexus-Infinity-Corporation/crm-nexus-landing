---
const channels = [
  { icon: '📘', bg: '#1877F2', name: 'Facebook', items: ['Messenger', 'Comentarios', 'Lead Ads', 'Grupos'] },
  { icon: '📸', bg: 'linear-gradient(135deg,#833AB4,#E1306C,#F77737)', name: 'Instagram', items: ['DMs', 'Comentarios', 'Story Replies', 'Reels'] },
  { icon: '🎵', bg: '#010101', name: 'TikTok', items: ['Mensajes directos', 'Comentarios', 'TikTok Ads', 'LIVE'] },
  { icon: '📱', bg: 'linear-gradient(135deg,#00D4FF,#7B2FFF)', name: 'App Móvil', items: ['Chat In-App', 'VoIP Calls', 'Push Notifications', 'Video'] },
  { icon: '💬', bg: '#25D366', name: 'WhatsApp', items: ['API Oficial', 'Broadcast', 'Templates', 'Botones interactivos'] },
  { icon: '📧', bg: '#EA4335', name: 'Email & SMS', items: ['Campañas', 'Transaccional', 'Automatización', 'Templates HTML'] },
];
---

<section class="py-[100px] relative" id="channels">
  <div class="max-w-[1280px] mx-auto px-6">
    <div class="text-center mb-14">
      <div class="inline-flex items-center gap-2 font-mono text-[11px] tracking-[3px] text-primary uppercase bg-[rgba(0,212,255,0.08)] border border-[rgba(0,212,255,0.4)] px-4 py-1.5 rounded-full mb-5">
        <span class="w-1.5 h-1.5 bg-primary rounded-full animate-pulse-dot"></span>
        Canales Integrados
      </div>
      <h2 class="font-display text-[clamp(32px,4vw,52px)] font-bold leading-[1.1] gradient-text mb-5">Donde están tus clientes,<br/>Nexus está presente</h2>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-[18px]">
      {channels.map(ch => (
        <div class="observe-anim bg-bg-card border border-[rgba(0,212,255,0.15)] rounded-2xl p-6 text-center transition-all hover:border-[rgba(0,212,255,0.4)] hover:-translate-y-1 hover:shadow-glow-primary">
          <div class="w-[52px] h-[52px] rounded-2xl flex items-center justify-center text-2xl mx-auto mb-3" style={`background: ${ch.bg}`}>{ch.icon}</div>
          <h4 class="font-display text-sm mb-2.5">{ch.name}</h4>
          <ul class="list-none flex flex-col gap-0.5">
            {ch.items.map(item => <li class="text-xs text-text-muted">{item}</li>)}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
