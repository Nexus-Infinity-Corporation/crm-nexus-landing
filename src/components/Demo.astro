---
interface Props {
  source?: 'CRM' | 'ERP' | 'MAIN';
}
const { source = 'CRM' } = Astro.props;
---

<section class="py-16 sm:py-[100px] relative" id="demo" data-source={source}>
  <div class="max-w-[1280px] mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-[70px] items-center">
      <!-- Left -->
      <div>
        <div class="inline-flex items-center gap-2 font-mono text-[11px] tracking-[3px] text-primary uppercase bg-[rgba(0,212,255,0.08)] border border-[rgba(0,212,255,0.4)] px-4 py-1.5 rounded-full mb-5">
          <span class="w-1.5 h-1.5 bg-primary rounded-full animate-pulse-dot"></span>
          <span class="t-en">Ready to get started?</span>
          <span class="t-es hidden">¿Listo para empezar?</span>
        </div>
        <h2 class="font-display text-[clamp(32px,4vw,52px)] font-bold leading-[1.1] gradient-text mb-5">
          <span class="t-en">Request your<br/>Personalized Demo</span>
          <span class="t-es hidden">Solicita tu Demo<br/>Personalizada</span>
        </h2>
        <p class="text-lg text-text-muted leading-[1.7] max-w-[600px]">
          <span class="t-en">Schedule a 30-minute session. We’ll show you the platform configured for your specific industry.</span>
          <span class="t-es hidden">Agenda una sesión de 30 minutos. Te mostramos la plataforma configurada para tu industria específica.</span>
        </p>
        <div class="flex flex-col gap-2.5 mt-7">
          {[
            { en: 'No credit card required',          es: 'Sin tarjeta de crédito requerida' },
            { en: '14-day free trial',                 es: 'Prueba gratuita de 14 días' },
            { en: 'Free onboarding included',          es: 'Onboarding incluido sin costo' },
            { en: 'Setup in less than 2 hours',        es: 'Configuración en menos de 2 horas' },
          ].map(b => (
            <div class="flex items-center gap-2.5 text-sm text-text-muted">
              <span class="text-accent2 font-bold">✓</span>
              <span class="t-en">{b.en}</span>
              <span class="t-es hidden">{b.es}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: Form -->
      <div class="bg-bg-card border border-[rgba(0,212,255,0.4)] rounded-2xl p-5 sm:p-8 shadow-glow-primary">
        <div class="font-display text-[17px] font-bold mb-5 text-center text-primary">
          <span class="t-en">Schedule your <span>{source}</span> Free Demo</span>
          <span class="t-es hidden">Agenda tu Demo <span>{source}</span> Gratis</span>
        </div>

        <!-- Success message (hidden by default) -->
        <div id="demo-form-success" class="hidden text-center py-6">
          <div class="text-4xl mb-3">🎉</div>
          <p class="font-display text-lg font-bold text-primary mb-2">
            <span class="t-en">Request sent!</span>
            <span class="t-es hidden">¡Solicitud enviada!</span>
          </p>
          <p class="text-sm text-text-muted mb-5">
            <span class="t-en">We'll be in touch within 2 hours. Or book your slot right now:</span>
            <span class="t-es hidden">Te contactaremos en las próximas 2 horas. O agenda tu espacio ahora mismo:</span>
          </p>
          <a
            href="https://calendly.com/sale-nexusinfinitycorp/30min"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2.5 font-mono text-[11px] tracking-[2px] uppercase px-6 py-3 rounded-full bg-gradient-to-br from-secondary to-accent text-white font-bold hover:shadow-[0_0_24px_rgba(123,47,255,0.5)] transition-all duration-300"
          >
            📅
            <span class="t-en">Book on Calendly</span>
            <span class="t-es hidden">Agendar en Calendly</span>
          </a>
        </div>

        <!-- Error message (hidden by default) -->
        <div id="demo-form-error" class="hidden mb-4 px-4 py-3 rounded-lg bg-[rgba(255,60,60,0.1)] border border-[rgba(255,60,60,0.4)] text-sm text-red-400 text-center"></div>

        <!-- Form fields -->
        <div id="demo-form-fields">
        <div class="mb-3.5">
          <label class="block text-[11px] text-text-muted mb-1.5 font-mono">
            <span class="t-en">Full name</span>
            <span class="t-es hidden">Nombre completo</span>
          </label>
          <input id="demo-field-name" type="text" placeholder="Juan García" required class="w-full bg-bg-dark border border-[rgba(0,212,255,0.15)] rounded-lg px-3.5 py-2.5 text-text-base font-body text-[13px] transition-all focus:outline-none focus:border-primary focus:shadow-[0_0_0_3px_rgba(0,212,255,0.1)] placeholder:text-text-dim" />
        </div>
        <div class="mb-3.5">
          <label class="block text-[11px] text-text-muted mb-1.5 font-mono">
            <span class="t-en">Company</span>
            <span class="t-es hidden">Empresa</span>
          </label>
          <input id="demo-field-company" type="text" placeholder="My Company Inc" class="w-full bg-bg-dark border border-[rgba(0,212,255,0.15)] rounded-lg px-3.5 py-2.5 text-text-base font-body text-[13px] transition-all focus:outline-none focus:border-primary focus:shadow-[0_0_0_3px_rgba(0,212,255,0.1)] placeholder:text-text-dim" />
        </div>
        <div class="mb-3.5">
          <label class="block text-[11px] text-text-muted mb-1.5 font-mono">
            <span class="t-en">Corporate email</span>
            <span class="t-es hidden">Email corporativo</span>
          </label>
          <input id="demo-field-email" type="email" placeholder="juan@empresa.com" required class="w-full bg-bg-dark border border-[rgba(0,212,255,0.15)] rounded-lg px-3.5 py-2.5 text-text-base font-body text-[13px] transition-all focus:outline-none focus:border-primary focus:shadow-[0_0_0_3px_rgba(0,212,255,0.1)] placeholder:text-text-dim" />
        </div>
        <div class="mb-3.5">
          <label class="block text-[11px] text-text-muted mb-1.5 font-mono">
            <span class="t-en">Phone</span>
            <span class="t-es hidden">Teléfono</span>
          </label>
          <input id="demo-field-phone" type="tel" placeholder="+1 555 0000" class="w-full bg-bg-dark border border-[rgba(0,212,255,0.15)] rounded-lg px-3.5 py-2.5 text-text-base font-body text-[13px] transition-all focus:outline-none focus:border-primary focus:shadow-[0_0_0_3px_rgba(0,212,255,0.1)] placeholder:text-text-dim" />
        </div>
        <div class="mb-5">
          <label class="block text-[11px] text-text-muted mb-1.5 font-mono">
            <span class="t-en">How many agents does your team have?</span>
            <span class="t-es hidden">¿Cuántos agentes tiene tu equipo?</span>
          </label>
          <select id="demo-field-agents" class="w-full bg-bg-dark border border-[rgba(0,212,255,0.15)] rounded-lg px-3.5 py-2.5 text-text-base font-body text-[13px] transition-all focus:outline-none focus:border-primary focus:shadow-[0_0_0_3px_rgba(0,212,255,0.1)]">
            <option>1-5</option>
            <option>6-20</option>
            <option>21-50</option>
            <option>50+</option>
          </select>
        </div>
        <button
          id="demo-submit-btn"
          type="button"
          class="btn-primary-glow w-full flex items-center justify-center gap-2.5 bg-gradient-to-br from-primary to-secondary text-white font-bold text-[15px] px-8 py-[15px] rounded-full border-none cursor-pointer shadow-glow-primary disabled:opacity-60 disabled:cursor-not-allowed"
        >
          <span class="relative z-10 t-en">🚀 Request Free Demo</span>
          <span class="relative z-10 t-es hidden">🚀 Solicitar Demo Gratuita</span>
        </button>
        <p class="text-center text-[11px] text-text-dim mt-2.5">
          <span class="t-en">No spam. You agree to our Privacy Policy.</span>
          <span class="t-es hidden">Sin spam. Aceptas nuestra Política de Privacidad.</span>
        </p>
        </div><!-- /demo-form-fields -->
      </div>
    </div>
  </div>
</section>

<script>
  import { sendDemoEmail } from '@/scripts/send-email';

  function initDemoForm() {
    const section     = document.getElementById('demo');
    if (!section) return;
    const formSource  = (section.dataset.source ?? 'CRM') as 'CRM' | 'ERP' | 'MAIN';

    const submitBtn   = document.getElementById('demo-submit-btn') as HTMLButtonElement | null;
    const formFields  = document.getElementById('demo-form-fields');
    const formSuccess = document.getElementById('demo-form-success');
    const formError   = document.getElementById('demo-form-error') as HTMLElement | null;

    const fieldName    = document.getElementById('demo-field-name')    as HTMLInputElement | null;
    const fieldCompany = document.getElementById('demo-field-company') as HTMLInputElement | null;
    const fieldEmail   = document.getElementById('demo-field-email')   as HTMLInputElement | null;
    const fieldPhone   = document.getElementById('demo-field-phone')   as HTMLInputElement | null;
    const fieldAgents  = document.getElementById('demo-field-agents')  as HTMLSelectElement | null;

    if (!submitBtn || !formFields || !formSuccess || !formError || !fieldName || !fieldEmail || !fieldAgents) return;

    function getCurrentLang(): 'en' | 'es' {
      return (localStorage.getItem('nxLang') as 'en' | 'es' | null) === 'es' ? 'es' : 'en';
    }

    function applyLangVisibility(lang: 'en' | 'es') {
      const show = lang === 'en' ? '.t-en' : '.t-es';
      const hide = lang === 'en' ? '.t-es' : '.t-en';
      section!.querySelectorAll<HTMLElement>(show).forEach(el => el.classList.remove('hidden'));
      section!.querySelectorAll<HTMLElement>(hide).forEach(el => el.classList.add('hidden'));
    }

    submitBtn.addEventListener('click', async () => {
      const lang = getCurrentLang();

      if (!fieldName.value.trim() || !fieldEmail.value.trim()) {
        formError.textContent = lang === 'es'
          ? 'Por favor completa los campos requeridos (nombre y email).'
          : 'Please fill in the required fields (name and email).';
        formError.classList.remove('hidden');
        return;
      }

      formError.classList.add('hidden');
      submitBtn.disabled = true;
      submitBtn.innerHTML = lang === 'es'
        ? '<span class="relative z-10">⏳ Enviando...</span>'
        : '<span class="relative z-10">⏳ Sending...</span>';

      const result = await sendDemoEmail({
        name:    fieldName.value.trim(),
        company: fieldCompany?.value.trim() ?? '',
        email:   fieldEmail.value.trim(),
        phone:   fieldPhone?.value.trim() ?? '',
        agents:  fieldAgents.value,
        lang,
        source:  formSource,
      });

      if (result.success) {
        formFields.classList.add('hidden');
        formSuccess.classList.remove('hidden');
        applyLangVisibility(lang);
      } else {
        submitBtn.disabled = false;
        submitBtn.innerHTML = lang === 'es'
          ? '<span class="relative z-10">🚀 Solicitar Demo Gratuita</span>'
          : '<span class="relative z-10">🚀 Request Free Demo</span>';
        formError.textContent = result.error ?? (lang === 'es'
          ? 'Algo salió mal. Intenta de nuevo.'
          : 'Something went wrong. Please try again.');
        formError.classList.remove('hidden');
      }
    });
  }

  document.addEventListener('astro:page-load', initDemoForm);
</script>
