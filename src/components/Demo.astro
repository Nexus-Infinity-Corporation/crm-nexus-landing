---
import DemoForm from './DemoForm';
---

<section class="py-[100px] relative" id="demo">
  <div class="max-w-[1280px] mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-[70px] items-center">
      <!-- Left -->
      <div>
        <div class="inline-flex items-center gap-2 font-mono text-[11px] tracking-[3px] text-primary uppercase bg-[rgba(0,212,255,0.08)] border border-[rgba(0,212,255,0.4)] px-4 py-1.5 rounded-full mb-5">
          <span class="w-1.5 h-1.5 bg-primary rounded-full animate-pulse-dot"></span>
          ¿Listo para empezar?
        </div>
        <h2 class="font-display text-[clamp(32px,4vw,52px)] font-bold leading-[1.1] gradient-text mb-5">Solicita tu Demo<br/>Personalizada</h2>
        <p class="text-lg text-text-muted leading-[1.7] max-w-[600px]">Agenda una sesión de 30 minutos. Te mostramos la plataforma configurada para tu industria específica.</p>
        <div class="flex flex-col gap-2.5 mt-7">
          {[
            'Sin tarjeta de crédito requerida',
            'Prueba gratuita de 14 días',
            'Onboarding incluido sin costo',
            'Configuración en menos de 2 horas',
          ].map(b => (
            <div class="flex items-center gap-2.5 text-sm text-text-muted">
              <span class="text-accent2 font-bold">✓</span> {b}
            </div>
          ))}
        </div>
      </div>

      <!-- Right: Form -->
      <div class="bg-bg-card border border-[rgba(0,212,255,0.4)] rounded-2xl p-8 shadow-glow-primary">
        <div class="font-display text-[17px] font-bold mb-5 text-center text-primary">Agenda tu Demo Gratis</div>
        <DemoForm client:load />
      </div>
    </div>
  </div>
</section>
